---
import Layout from './Layout.astro';
import '../styles/individual.css';
export interface FaqItem {
    q: string;
    a: string;
}

interface Props {
    title?: string;
    description?: string;
    pageTitle?: string;
    heroImage?: string;
    heroImageAlt?: string;
    schema?: Record<string, any>; 

    // FAQ 
    faqSectionTitle?: string;
    faqItems?: FaqItem[];

    // CTA 
    ctaTitle?: string;
    ctaDescription?: string | string[];
    ctaButtonUrl?: string;

    // Sources & Resources 
    sourcesTitle?: string;
    sourcesList?: { label: string; url?: string }[];
    resourcesTitle?: string;
    resourcesList?: { label: string; url: string }[];
}

const {
    title = 'Industrial Solutions',
    description = 'Reliable industrial solutions built for performance.',
    pageTitle = 'Industrial Solutions',
    heroImage = '',
    heroImageAlt = '',
    schema,

    // FAQ 
    faqSectionTitle = 'FAQ: Sourcing Inconel 718 Forgings',
    faqItems = [],

    // CTA 
    ctaTitle = 'Request an Inconel 718 Technical Consultation',
    ctaDescription = 'Direct access to our engineering team. Feasibility reviews delivered within 48 hours.',
    ctaButtonUrl = '/contact',

    // Resources & Sources 
    sourcesTitle = 'Sources',
    sourcesList = [],
    resourcesTitle = 'Our Internal Resources for Die Casting, Investment casting, Forging and Sand Casting',
    resourcesList = []
} = Astro.props;

// check ctaDescription array
const isCtaDescArray = Array.isArray(ctaDescription);
---

<Layout title={title} description={description}>
    {schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <!-- ========================================
         Compact Hero Section 
         ======================================== -->
    <section class="relative w-full overflow-hidden bg-[#0363ce] py-12 sm:py-16 lg:py-33">
        
        <!-- Background Image -->
        {heroImage && (
            <div class="absolute inset-0 z-0">
                <img
                    src={heroImage}
                    alt={heroImageAlt || pageTitle}
                    class="w-full h-full object-cover object-center"
                    loading="eager"
                    decoding="async"
                />
            </div>
        )}

        <!-- Centered Content -->
        <div class="relative z-10 w-full px-0 text-center">
            <div class="w-full">
                <h1 
                    class="text-4xl sm:text-4xl lg:text-6xl leading-[1.2] text-white tracking-tight w-full"
                    set:html={pageTitle}
                />
            </div>
        </div>

    </section>

   <section class="w-full pt-8 pb-14 lg:pt-12 lg:pb-16">
        <div class="mx-auto max-w-7xl px-6 sm:px-12">
            <div class="individual-content">
                <slot />
            </div>
        </div>
    </section>

    <div class="layout-sections-wrapper">
        <slot name="full-width" />
    </div>

    <section class="w-full bg-white  border-slate-200 py-14 lg:py-4 text-slate-800">
        <div class="w-full max-w-7xl mx-auto px-6 sm:px-12 space-y-12">

            {faqItems && faqItems.length > 0 && (
                <div class="space-y-6">
                    <h2 
                        class="text-3xl sm:text-4xl lg:text-4xl font-normal leading-tight text-black mt-10 mb-5"
                    >
                        {faqSectionTitle}
                    </h2>

                    <div class="space-y-6">
                        {faqItems.map((item) => (
                            <div class="space-y-2">
                                <p class="text-base font-semibold text-[#0B192C]">
                                    Q: {item.q}
                                </p>
                                <p class="text-base text-slate-600 leading-relaxed border-slate-200">
                                    A: {item.a}
                                </p>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            <div class="py-8 text-center  border-slate-100 my-10">
                <h2 
                    class="text-3xl sm:text-4xl lg:text-4xl font-normal leading-tight text-black mt-10 mb-5"
                >
                    {ctaTitle}
                </h2>

                {ctaDescription && (
                    <div class="max-w-3xl mx-auto mb-8 text-slate-600 text-sm sm:text-base leading-relaxed text-center">
                        {isCtaDescArray ? (
                            <ul class="list-disc pl-6 space-y-2 inline-block text-left">
                                {(ctaDescription as string[]).map((point) => (
                                    <li>{point}</li>
                                ))}
                            </ul>
                        ) : (
                            <p class="text-center italic text-slate-500">{ctaDescription}</p>
                        )}
                    </div>
                )}

                <div class="flex justify-center">
                    <a
                        href="/oscar/request-a-quote"
                        class="inline-flex items-center justify-center rounded-full bg-brand-green px-8 py-3.5 text-base font-semibold text-white shadow-md transition hover:bg-[#5aaa14] hover:shadow-lg"
                    >
                        Request Quote
                    </a>
                </div>
            </div>

            {sourcesList && sourcesList.length > 0 && (
                <div class="space-y-4">
                    <h2 
                        class="text-3xl sm:text-4xl lg:text-4xl font-normal leading-tight text-black mt-10 mb-5"
                    >
                        {sourcesTitle}
                    </h2>
                    <ul class="list-disc pl-6 space-y-2 text-sm sm:text-base text-slate-600">
                        {sourcesList.map((source) => (
                            <li>
                                {source.url ? (
                                    <a href={source.url} class="text-[#0363CE] hover:underline" target="_blank" rel="noopener noreferrer">
                                        {source.label}
                                    </a>
                                ) : (
                                    <span>{source.label}</span>
                                )}
                            </li>
                        ))}
                    </ul>
                </div>
            )}

            {resourcesList && resourcesList.length > 0 && (
                <div class="space-y-4 pt-4">
                    <h2 
                        class="text-3xl sm:text-4xl lg:text-4xl font-normal leading-tight text-black mt-10 mb-5"
                    >
                        {resourcesTitle}
                    </h2>
                    <ul class="list-disc pl-6 space-y-2 text-sm sm:text-base text-slate-600">
                        {resourcesList.map((res) => (
                            <li>
                                <a href={res.url} class="text-[#0363CE] hover:underline font-medium">
                                    {res.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            )}

        </div>
    </section>
<style>
    /* 1. 统一调整 section 本身的上下高度，并让其撑满整宽 */
    .layout-sections-wrapper :global(section) {
        padding-top: 2rem !important;    /* 相当于 py-18 */
        padding-bottom: 2rem !important; /* 相当于 py-18 */
        width: 100% !important;
        display: block !important;
    }
    .layout-sections-wrapper :global(section:first-child) {
        padding-top: 0rem !important;    /* 👈 调整这个值，来决定第一个 section 距离 Hero 的高度 */
        padding-bottom: 2rem !important; /* 保持下方 Padding 与其他 section 相同 */
    }

    /* 2. 统一约束 section 里的直接子容器（把 mx-auto max-w-7xl px-6 sm:px-12 搬到这里） */
    .layout-sections-wrapper :global(section > div) {
        margin-left: auto !important;
        margin-right: auto !important;
        max-width: 80rem !important;      /* 7xl = 1280px / 80rem */
        width: 100% !important;
        
        /* 移动端的左右安全留白 px-6 (24px) */
        padding-left: 1.5rem !important;
        padding-right: 1.5rem !important;
    }

    /* 3. 在平板及桌面端自动放大左右留白 sm:px-12 (48px) */
    @media (min-width: 640px) {
        .layout-sections-wrapper :global(section > div) {
            padding-left: 3rem !important;
            padding-right: 3rem !important;
        }
    }
</style>
</Layout>