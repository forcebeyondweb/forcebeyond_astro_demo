---
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Industrial Solutions',
    description = 'Reliable industrial solutions built for performance.'
} = Astro.props;

---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/png" href="/oscar/media/webfavicon_0.png" />
        <link rel="icon" href="/oscar/media/webfavicon_0.png" />
        <title>{title}</title>

<!-- ================================
     Global Font System
     Change fonts here only
     ================================ -->

<!-- Google Font: Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link 
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" 
    rel="stylesheet" 
/>

<style is:global>
    :root {
        --font-body: 'Open Sans', Arial, sans-serif;
        --font-heading: 'Oswald', 'Arial Narrow', sans-serif;
        --brand-blue: #0363ce;
    }

    html,
    body {
        font-family: var(--font-body);
        width: 100%;
        max-width: 100%;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
        font-family: var(--font-heading);
    }
    h2 {
        color: var(--brand-blue);
    }

    /* Active navigation state */
    .nav-link-active {
        color: #0363ce !important;
        font-weight: 800;
    }

    .dropdown-item-active {
        color: #0363ce !important;
        background-color: #f8fafc;
    }

    .mobile-nav-active {
        color: #0363ce !important;
        font-weight: 800;
        background-color: #f8fafc;
    }
</style>

<slot name="head" />
        
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@graph": [
                    {
                        "@type": "IndustrialBusiness",
                        "@id": "https://www.forcebeyond.store/oscar/#organization",
                        "name": "ForceBeyond",
                        "description": "ForceBeyond provides custom metal component manufacturing solutions including investment casting, die casting, forging, and CNC machining.",
                        "image": "https://www.forcebeyond.store/oscar/forcebeyond-logo.png",
                        "knowsAbout": [
                            "Investment Casting",
                            "Die Casting",
                            "Forging",
                            "CNC Machining",
                            "Tier 1.5 Supply Chain Management"
                        ]
                    }
                ]
            }
        </script>
    </head>
