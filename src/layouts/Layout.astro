                    <a href="/oscar/blog" class="hover:text-amber-400 transition">
                        Knowledge Base & Technical Blog
                    </a>

                    <a href="/oscar/careers" class="hover:text-amber-400 transition">
                        Professional Opportunities (Careers)
                    </a>
                </ul>
            </div>
        </div>

        <div class="pt-6 border-t border-slate-600/40 flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
            <p class="text-slate-400 text-xs">
                &copy; 2026 ForceBeyond. All rights reserved.
            </p>
            
            <div class="flex gap-6 text-xs text-slate-400">
                <a href="/oscar/privacy-policy" class="hover:text-white transition">
                    Privacy Policy
                </a>

                <a href="#" class="hover:text-white transition">
                    Back to Top ↑
                </a>
            </div>
        </div>
    </div>
</footer>
<script>
    function initMobileMenu() {
        const openButton = document.getElementById('mobile-menu-button');
        const closeButton = document.getElementById('mobile-menu-close');
        const menu = document.getElementById('mobile-menu');
        const links = document.querySelectorAll('.mobile-menu-link');

        if (!openButton || !closeButton || !menu) return;

        const openMenu = () => {
            menu.classList.remove('hidden');
            document.body.classList.add('overflow-x-hidden');
        };

        const closeMenu = () => {
            menu.classList.add('hidden');
            document.body.classList.remove('overflow-x-hidden');
        };

        openButton.onclick = openMenu;
        closeButton.onclick = closeMenu;

        links.forEach((link) => {
            link.addEventListener('click', closeMenu);
        });
    }


    function initActiveNavigation() {
        const header = document.querySelector('header');
        if (!header) return;

        const normalizePath = (path: string): string => {
            return path.replace(/\/$/, '');
        };

        const currentPath = normalizePath(window.location.pathname);

        const isSamePage = (href:string):boolean => {
            try {
                const url = new URL(href, window.location.origin);
                const linkPath = normalizePath(url.pathname);

                if (linkPath === currentPath) return true;

                // Home page compatibility: /oscar and /oscar/
                if ((currentPath === '/oscar' || currentPath === '/oscar/') && linkPath === '/oscar') {
                    return true;
                }

                return false;
            } catch {
                return false;
            }
        };

        const isInsideGroup = (rootPath:string):boolean => {
            const cleanRoot = normalizePath(rootPath);
            return currentPath === cleanRoot || currentPath.startsWith(cleanRoot + '/');
        };

        // Exact active state for every real page link
        header.querySelectorAll('a[href]').forEach((link) => {
            const href = link.getAttribute('href') || '';
            
            if (href.includes('/request-a-quote')) return;

            if (!isSamePage(href)) return;

            link.setAttribute('aria-current', 'page');

            if (link.classList.contains('mobile-menu-link')) {
                link.classList.add('mobile-nav-active');
            } else if (link.closest('[class*="shadow-2xl"]')) {
                link.classList.add('dropdown-item-active');
            } else {
                link.classList.add('nav-link-active');
            }
        });

        // Active state for top-level desktop dropdown labels
        const desktopGroups = [
            { label: 'About Us', root: '/oscar/about-us' },
            { label: 'Industries', root: '/oscar/industries' },
            { label: 'Capabilities', root: '/oscar/capabilities' },
            { label: 'Solutions', root: '/oscar/solutions' },
            { label: 'Services', root: '/oscar/services' },
        ];

        desktopGroups.forEach(({ label, root }) => {
            if (!isInsideGroup(root)) return;

            header.querySelectorAll('nav.hidden a').forEach((link) => {
                const linkText = (link.childNodes[0]?.textContent || link.textContent || '').trim();
                if (linkText === label) {
                    link.classList.add('nav-link-active');
                }
            });
        });

        // Active state for mobile dropdown summaries
        const mobileGroups = [
            { label: 'About Us', root: '/oscar/about-us' },
            { label: 'Industries', root: '/oscar/industries' },
            { label: 'Capabilities', root: '/oscar/capabilities' },
            { label: 'Solutions', root: '/oscar/solutions' },
            { label: 'Services', root: '/oscar/services' },
        ];

        mobileGroups.forEach(({ label, root }) => {
            if (!isInsideGroup(root)) return;

            header.querySelectorAll('#mobile-menu summary').forEach((summary) => {
                const summaryLabel = summary.querySelector('span')?.textContent?.trim();
                if (summaryLabel === label) {
                    summary.classList.add('mobile-nav-active');
                }
            });
        });
    }

    initMobileMenu();
    initActiveNavigation();
    document.addEventListener('DOMContentLoaded', () => {
        initMobileMenu();
        initActiveNavigation();
    });
    document.addEventListener('astro:page-load', () => {
        initMobileMenu();
        initActiveNavigation();
    });
</script>
    </body>
</html>