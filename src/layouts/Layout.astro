---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Industrial Solutions',
	description = 'Reliable industrial solutions built for performance.'
} = Astro.props;

const navigation = [
	{ label: 'Home', href: '/' },
	{ label: 'Capabilities', href: '/capabilities' },
	{ label: 'Industries', href: '/industries' },
	{ label: 'Solutions', href: '/solutions', children: [{ label: 'Inconel 718 Forging', href: '/solutions/inconel-718-forging' }] },
	{ label: 'Contact Us', href: '/contact-us' }
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
		<slot name="head" />
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@graph": [
					{
						"@type": "IndustrialBusiness",
						"@id": "https://fbwebdemo.netlify.app/#organization",
						"name": "ForceBeyond",
						"description": "ForceBeyond provides custom metal component manufacturing solutions including investment casting, die casting, forging, stainless steel casting, titanium casting, sand casting, CNC machining, and secondary operations for industrial applications.",
						"image": "https://fbwebdemo.netlify.app/favicon.svg",
						"knowsAbout": [
							"Investment Casting",
							"Die Casting",
							"Forging",
							"CNC Machining",
							"Stainless Steel Casting",
							"Titanium Casting",
							"Sand Casting",
							"Tier 1.5 Supply Chain Management"
						],
						"areaServed": [
							{ "@type": "AdministrativeArea", "name": "Aerospace Market" },
							{ "@type": "AdministrativeArea", "name": "Automotive Market" },
							{ "@type": "AdministrativeArea", "name": "Energy Market" },
							{ "@type": "AdministrativeArea", "name": "Oil & Gas Market" },
							{ "@type": "AdministrativeArea", "name": "Industrial Machinery Market" },
							{ "@type": "AdministrativeArea", "name": "Medical Market" }
						]
					},
					{
						"@type": "FAQPage",
						"@id": "https://fbwebdemo.netlify.app/#faq",
						"mainEntity": [
							{
								"@type": "Question",
								"name": "What does ForceBeyond manufacture?",
								"acceptedAnswer": {
									"@type": "Answer",
									"text": "ForceBeyond provides custom metal component manufacturing solutions including investment casting, die casting, forging, stainless steel casting, titanium casting, sand casting, CNC machining, and secondary operations."
								}
							},
							{
								"@type": "Question",
								"name": "What industries does ForceBeyond serve?",
								"acceptedAnswer": {
									"@type": "Answer",
									"text": "ForceBeyond supports customers in industries such as aerospace, automotive, energy, oil and gas, medical, industrial machinery, electrical equipment, and chemical processing."
								}
							},
							{
								"@type": "Question",
								"name": "Does ForceBeyond provide CNC machining?",
								"acceptedAnswer": {
									"@type": "Answer",
									"text": "Yes. ForceBeyond provides CNC machining and secondary operations for cast, forged, and engineered metal components that require dimensional accuracy and production-ready finishing."
								}
							},
							{
								"@type": "Question",
								"name": "What information is needed for a quote?",
								"acceptedAnswer": {
									"@type": "Answer",
									"text": "For a quote, customers should provide drawings, material requirements, target quantity, tolerance expectations, finishing requirements, application details, and any inspection or documentation needs."
								}
							},
							{
								"@type": "Question",
								"name": "Can ForceBeyond support both prototypes and production?",
								"acceptedAnswer": {
									"@type": "Answer",
									"text": "ForceBeyond can support customers from early manufacturing review and prototype planning through production sourcing, machining, finishing, inspection, and ongoing supply coordination."
								}
							}
						]
					}
				]
			}
		</script>
	</head>
	<body class="min-h-screen bg-slate-900 text-white antialiased">
		<header class="sticky top-0 z-50 border-b border-white/10 bg-slate-900/95 shadow-lg shadow-slate-950/20 backdrop-blur">
			<div class="mx-auto flex min-h-18 max-w-7xl items-center justify-between gap-6 px-4 py-3 sm:px-6 lg:px-8">
				<a href="/" class="shrink-0 text-lg font-bold tracking-[0.08em] text-white" aria-label="ForceBeyond home">
					ForceBeyond<span class="text-orange-500">.</span>
				</a>

				<nav class="hidden items-center gap-7 lg:flex" aria-label="Global navigation">
					{navigation.map((item) => item.children ? (
						<details class="group relative">
							<summary class="flex cursor-pointer list-none items-center gap-1 text-sm font-semibold tracking-wide text-slate-200 transition hover:text-orange-500 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-400">
								{item.label}
								<svg class="h-4 w-4 transition group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.1 1.02l-4.25 4.5a.75.75 0 0 1-1.1 0l-4.25-4.5a.75.75 0 0 1 .02-1.04Z" clip-rule="evenodd" /></svg>
							</summary>
							<div class="absolute left-0 top-[calc(100%+1rem)] w-64 border border-white/10 bg-slate-900 p-2 shadow-xl shadow-slate-950/40">
								{item.children.map((child) => <a class="block px-3 py-3 text-sm font-semibold text-slate-100 transition hover:bg-white/5 hover:text-orange-500 focus-visible:bg-white/5 focus-visible:text-orange-500" href={child.href}>{child.label}</a>)}
							</div>
						</details>
					) : (
						<a class="text-sm font-semibold tracking-wide text-slate-200 transition hover:text-orange-500 focus-visible:text-orange-500" href={item.href}>{item.label}</a>
					))}
				</nav>

				<a href="/request-a-quote" class="hidden rounded-sm bg-orange-600 px-5 py-2.5 text-sm font-bold tracking-wide text-white transition hover:bg-orange-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-400 lg:inline-flex">
					Request a Quote
				</a>

				<details class="group relative lg:hidden">
					<summary class="flex cursor-pointer list-none items-center gap-2 rounded-sm border border-white/20 px-3 py-2 text-sm font-semibold text-white transition hover:border-orange-500 hover:text-orange-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-400">
						<span>Menu</span>
						<svg class="h-4 w-4 transition group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.1 1.02l-4.25 4.5a.75.75 0 0 1-1.1 0l-4.25-4.5a.75.75 0 0 1 .02-1.04Z" clip-rule="evenodd" /></svg>
					</summary>
					<nav class="absolute right-0 top-[calc(100%+0.75rem)] w-64 border border-white/10 bg-slate-900 p-3 shadow-2xl shadow-slate-950/40" aria-label="Mobile global navigation">
						{navigation.map((item) => item.children ? (
							<details class="border-b border-white/10">
								<summary class="flex cursor-pointer list-none items-center justify-between px-3 py-3 text-sm font-semibold text-slate-100 hover:bg-white/5 hover:text-orange-500 focus-visible:bg-white/5 focus-visible:text-orange-500">
									{item.label}
									<svg class="h-4 w-4 transition group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.1 1.02l-4.25 4.5a.75.75 0 0 1-1.1 0l-4.25-4.5a.75.75 0 0 1 .02-1.04Z" clip-rule="evenodd" /></svg>
								</summary>
								{item.children.map((child) => <a class="block border-t border-white/10 bg-slate-950/40 px-6 py-3 text-sm font-semibold text-slate-200 hover:text-orange-500 focus-visible:text-orange-500" href={child.href}>{child.label}</a>)}
							</details>
						) : (
							<a class="block border-b border-white/10 px-3 py-3 text-sm font-semibold text-slate-100 last:border-0 hover:bg-white/5 hover:text-orange-500 focus-visible:bg-white/5 focus-visible:text-orange-500" href={item.href}>{item.label}</a>
						))}
						<a href="/request-a-quote" class="mt-3 block rounded-sm bg-orange-600 px-4 py-3 text-center text-sm font-bold tracking-wide text-white hover:bg-orange-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-400">
							Request a Quote
						</a>
					</nav>
				</details>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="border-t border-white/10 bg-slate-900 text-white">
			<div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-3 lg:px-8 lg:py-16">
				<section class="lg:col-span-2" aria-labelledby="footer-contact-title">
					<p id="footer-contact-title" class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">Contact Us</p>
					<p class="mt-5 text-xl font-bold tracking-[0.12em] text-white">FORCEBEYOND</p>
					<address class="mt-4 max-w-md text-sm leading-7 text-slate-300 not-italic">261 Quigley Blvd, Suite 18, New Castle, Delaware 19720</address>
					<p class="mt-4 text-sm leading-7 text-slate-300">Phone: <a class="transition hover:text-orange-500" href="tel:+13029956588">(302) 995 6588</a> <span class="px-1 text-slate-500">|</span> Fax: (302) 355 1166 <span class="px-1 text-slate-500">|</span> Email: <a class="transition hover:text-orange-500" href="mailto:contact@forcebeyond.com">contact@forcebeyond.com</a></p>
					<div class="mt-7 flex flex-wrap gap-3" aria-label="Industrial certifications">
						<div class="border border-orange-500 bg-orange-600/10 px-4 py-3"><p class="text-xs font-bold tracking-[0.16em] text-orange-500 uppercase">CAGE#</p><p class="mt-1 font-bold text-white">1AMF7</p></div>
						<div class="border border-white/20 bg-white/5 px-4 py-3"><p class="text-xs font-bold tracking-[0.16em] text-slate-300 uppercase">Quality System</p><p class="mt-1 font-bold text-white">ISO 9001:2015 Certified</p></div>
					</div>
				</section>

				<nav aria-labelledby="footer-resources-title">
					<p id="footer-resources-title" class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">RESOURCES &amp; CAREER</p>
					<ul class="mt-5 space-y-3 text-sm font-semibold text-slate-200">
						<li><a class="transition hover:text-orange-500 focus-visible:text-orange-500" href="/resources/global-supply-chain-faqs">Global Supply Chain FAQs</a></li>
						<li><a class="transition hover:text-orange-500 focus-visible:text-orange-500" href="/resources/manufacturing-process-animations">Manufacturing Process Animations</a></li>
						<li><a class="transition hover:text-orange-500 focus-visible:text-orange-500" href="/jobs">Jobs</a></li>
					</ul>
				</nav>
			</div>
		</footer>
	</body>
</html>
