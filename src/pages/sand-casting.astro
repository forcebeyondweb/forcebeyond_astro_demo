---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Sand Casting: Large-Scale, Cost-Effective Metal Manufacturing';
const seoTitle = 'Custom Sand Casting Services | Ductile Iron, Steel & Aluminum | ForceBeyond';
const seoDescription = 'ForceBeyond provides custom sand casting services using green sand and resin/no-bake sand molding. Delivering heavy-duty ductile iron, steel, and A356 aluminum castings with complete Tier-1.5 CNC machining and NDT inspection.';

const faqs = [
    {
        q: "How does sand casting differ from investment casting?",
        a: "Sand casting uses a reusable pattern (usually wood or metal) to pack sand into a mold, which is then broken apart after the metal cools. It is highly cost-effective for large, heavy parts. Investment casting uses a ceramic shell built around a sacrificial wax pattern. It is much more expensive but yields exceptionally tight tolerances, very thin walls, and a beautiful surface finish."
    },
    {
        q: "Why use Ductile Iron instead of standard Gray Iron?",
        a: "Standard Gray Iron contains graphite in the shape of flakes, which makes the metal excellent at absorbing vibration but causes it to be somewhat brittle under impact. Ductile Iron is treated with magnesium to form the graphite into spheres (nodules). This gives Ductile Iron the high tensile strength, toughness, and impact resistance of steel, while maintaining the cost-effective castability of iron."
    },
    {
        q: "Can you achieve a smooth surface finish with sand casting?",
        a: "While standard green sand casting results in a somewhat rough, textured surface, ForceBeyond can utilize finer sand grains, specialized mold washes, and Resin (No-Bake) molding to significantly improve the as-cast surface finish. All critical mating surfaces will be precision CNC machined in-house."
    },
    {
        q: "How does Sand Casting compare to Permanent Mold Casting?",
        a: "The primary difference is the mold material. Sand casting uses expendable sand molds that must be broken apart for every single part, making it incredibly cost-effective for massive components or low-volume runs. Permanent mold casting (gravity die casting) uses reusable iron or steel molds. While permanent molds have much higher upfront tooling costs, they offer faster production cycle times, slightly tighter tolerances, and a denser grain structure for mid-to-high volume aluminum runs."
    }
];

// Sources 
const sources = [
    { label: 'American Foundry Society (AFS): "Sand Casting Technology & Applications"', url: 'https://www.afsinc.org' },
    { label: 'Ductile Iron Society (DIS)', url: 'https://www.ductile.org' },
    { label: 'ASM International: "Casting Design and Metallurgy"', url: 'https://www.asminternational.org' }
];

// Resources 
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];

// Service / Product Schema
const pageSchema = {
