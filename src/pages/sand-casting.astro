  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/sand-casting#webpage",
      "url": "https://www.forcebeyond.store/oscar/sand-casting",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      },
      "about": [
        {
          "@type": "Thing",
          "name": "Sand casting",
          "sameAs": "https://en.wikipedia.org/wiki/Sand_casting"
        },
        {
          "@type": "Thing",
          "name": "Ductile iron",
          "sameAs": "https://en.wikipedia.org/wiki/Ductile_iron"
        }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/sand-casting#service",
      "name": "Large-Scale Sand Casting Manufacturing Services",
      "serviceType": "Custom Sand Casting Services",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "Large-Scale & Heavy-Duty Sand Casting",
          "Automated Green Sand Molding Lines",
          "Resin / No-Bake Sand Molding for Multi-Ton Components",
          "Ferrous & Non-Ferrous Alloys (Ductile Iron, Gray Iron, Carbon Steel, A356 Aluminum)",
          "Complex Internal Coring & Fluid Cavities",
          "Heavy CNC Machining (VTLs & Horizontal Boring Mills)",
          "Non-Destructive Testing (MPI, UT) & ISO 9001:2015 Integration"
        ]
      },
      "areaServed": [
        { "@type": "Country", "name": "United States" },
        { "@type": "Country", "name": "South Korea" },
        { "@type": "Country", "name": "Taiwan" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Sand Casting Capabilities",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Green Sand & Resin Sand Molding",
              "description": "Scalable production of small-to-massive ferrous and non-ferrous components weighing from a few pounds up to multi-ton industrial castings."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Complex Internal Coring & Prototyping",
              "description": "Custom sand coring for intricate internal fluid passages, volutes, and pump housings with rapid wood/3D-printed sand prototyping capabilities."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Tier-1.5 Heavy CNC Machining & NDT Inspection",
              "description": "Turnkey secondary processing including VTL turning, horizontal boring, heat treatment, stress relieving, shot blasting, and MPI/UT testing."
            }
          }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/sand-casting#faq",
      "mainEntity": faqs.map(f => ({
