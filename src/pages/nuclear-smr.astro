---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Nuclear & SMR Precision Components for Next-Gen Energy';
const seoTitle = 'Nuclear & SMR Precision Components | ForceBeyond';
const seoDescription = 'ForceBeyond delivers AS9100-certified precision components for Small Modular Reactors (SMRs), micro-reactors, and Gen IV nuclear power systems.';

const faqs = [
    {
        q: "Why is AS9100 certification crucial for Nuclear SMR hardware?",
        a: "AS9100 certification mandates an unbroken chain of custody, proactive risk management, and micro-tolerance precision (±0.0005\") on difficult-to-machine superalloys—providing the exact audit-ready quality controls needed for Safety-Related nuclear applications."
    },
    {
        q: "Which superalloy grades does ForceBeyond recommend for Molten Salt Reactor (MSR) components?",
        a: "We recommend Inconel 625 and Hastelloy X. These alloys provide exceptional oxidation and corrosion resistance against fluoride and chloride salts at temperatures exceeding 1,200°F (650°C), while maintaining high creep-rupture strength."
    }
];

// Sources
const sources = [
    { label: 'ISO 9001:2015 Quality Management Systems Requirements', url: 'https://www.iso.org' },
    { label: 'AS9100 Aerospace & Safety-Critical Quality Management Standard', url: 'https://www.sae.org' },
    { label: 'ASTM International: Standards for Vacuum Investment Casting & Forgings', url: 'https://www.astm.org' }
];

// Resources
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];

// Page Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/nuclear-smr-components#webpage",
      "url": "https://www.forcebeyond.store/oscar/nuclear-smr-components",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      }
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/nuclear-smr-components#service",
      "name": "Nuclear & SMR Precision Component Manufacturing",
      "serviceType": "Safety-Critical Nuclear Power Components",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "Vacuum Precision Investment Casting (VIM)",
          "Seamless Rolled Ring Forging for Pressure Vessels",
          "Hot Isostatic Pressing (HIP) for 100% Structural Density",
          "AS9100 Rev D & ISO 9001:2015 Quality Systems",
          "Small Modular Reactors (SMR) & Micro-Reactor Hardware"
        ]
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Nuclear & SMR Capabilities",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Reactor Internals",
              "description": "Control rod drive mechanism housings, fuel spacers, and core grid plates manufactured from Inconel 718 and nuclear grade 316L."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Flow Control & Valves",
              "description": "Forged valve bodies and steam isolation valves engineered for molten salt and extreme cooling media."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Pressure Boundary Forgings",
              "description": "Heavy seamless rolled rings for reactor pressure vessel flanges and manway covers."
            }
          }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/nuclear-smr-components#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<IndividualPageLayout
    title={seoTitle}
    description={seoDescription}
    schema={pageSchema}
    pageTitle={pageTitle}
    heroImage="/oscar/media/die-casting-investment-casting-forging-cnc-high-precision-machining-title-bar-2.jpg"
    heroImageAlt="Forged Inconel 718 rings and high-performance industrial components"
    faqSectionTitle="Frequently Asked Questions: Nuclear & SMR Components"
    faqItems={faqs}
    ctaTitle="Ready to Power Next-Gen Nuclear Infrastructure?"
    ctaDescription="Partner with our engineering team for audit-ready, precision-crafted components built for safety-critical SMR and Gen IV applications."
    sourcesTitle="Sources"
    sourcesList={sources}
    resourcesTitle="Our Internal Resources for Die Casting, Investment casting, Forging and Sand Casting"
    resourcesList={internalResources}
>

    <div slot="full-width" class="individual-content">

        <section id="overview">
            <div class="content-container">
                
                <h2>Nuclear & SMR Precision Components for Next-Gen Energy</h2>

                <div class="grid gap-10 lg:grid-cols-2 lg:items-center mt-6">
                    <div>
                        <p>
                            ForceBeyond is an AS9100-certified, Tier-1.5 contract manufacturer specializing in safety-critical precision components for Small Modular Reactors (SMRs), micro-reactors, and Generation IV nuclear power systems. As global utilities and tech hyperscalers deploy dedicated Nuclear Microgrids to supply emission-free, gigawatt-scale power directly to AI data center campuses, ForceBeyond delivers the high-integrity hardware required for the nuclear renaissance.
                        </p>
                        <p>
                            Utilizing Vacuum Precision Casting, heavy-tonnage seamless ring rolling, and advanced 5-axis CNC machining, we manufacture reactor internals, flow control valve bodies, and pressure boundary forgings. Our tri-regional manufacturing network (USA, South Korea, Taiwan) guarantees absolute material traceability, zero-porosity metallurgical purity, and strict audit-ready compliance.
                        </p>
                    </div>
                    <div class="relative">
                        <div class="overflow-hidden">
                            <img
                                src="/oscar/media/nuclear-smr-components-overview-4k.webp"
                                alt="High-precision forged and machined reactor internal component for Small Modular Reactors."
                                class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500"
                            />
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section id="component-portfolio">
            <div class="content-container">
                <h2>Safety-Critical Component Portfolio & Material Matrix</h2>
                <p>
                    Advanced SMRs and advanced cooling loops (including molten salt, high-temperature gas, and liquid sodium) subject internal hardware to extreme neutron irradiation, thermal creep, and corrosive cooling media. ForceBeyond manufactures high-precision components engineered for 60+ year design lifespans:
                </p>
                <div class="content-table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th scope="col">Component Category</th>
                                <th scope="col">Primary Applications</th>
                                <th scope="col">Material Expertise</th>
                                <th scope="col">Technical Performance Attribute</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <th scope="row">Reactor Internals</th>
                                <td>Control Rod Drive Mechanism (CRDM) housings, fuel spacers, core grid plates</td>
                                <td>Inconel 718, Low-Cobalt Nuclear Grade 316L</td>
                                <td>Maintains high yield strength (1,035MPa) and dimensional stability under intense irradiation.</td>
                            </tr>
                            <tr>
                                <th scope="row">Flow Control & Valves</th>
                                <td>Forged valve bodies, steam isolation valves, main steamline fittings</td>
                                <td>Hastelloy X, Duplex 2205, Super Duplex</td>
                                <td>Superior resistance to hot stress corrosion cracking (SCC) and aggressive liquid cooling media.</td>
                            </tr>
                            <tr>
                                <th scope="row">Pressure Boundary</th>
                                <td>Reactor Pressure Vessel (RPV) forged rings, vessel flanges, manway covers</td>
                                <td>SA-508 Gr. 3, Inconel 625 (ASTM B564)</td>
                                <td>Heavy seamless rolled rings providing high hoop strength and fracture toughness under thermal pressure cycles.</td>
                            </tr>
                            <tr>
                                <th scope="row">Pump Components</th>
                                <td>Canned motor pump housings, precision-machined primary loop impellers</td>
                                <td>Ti-6Al-4V Titanium, Zirconium, Monel</td>
                                <td>Vacuum-cast and HIPed for 100% pressure-tight, zero-porosity fluid containment.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="strategic-solutions">
            <div class="content-container">
                <h2>Strategic Manufacturing Solutions for Advanced Nuclear</h2>
                <p>
                    ForceBeyond provides end-to-end manufacturing capabilities for primary loop cooling and reactor safety systems:
                </p>
                <ul>
                    <li>
                        <strong>Small Modular Reactors (SMRs):</strong> Factory-built, near-net-shape investment castings and forgings for modular reactor modules.
                    </li>
                    <li>
                        <strong>Micro-Reactors:</strong> High-integrity compact castings and structural forgings for decentralized and mobile clean power units.
                    </li>
                    <li>
                        <strong>Generation IV & Molten Salt Reactors:</strong> Specialized vacuum superalloy casting (Inconel 625, Hastelloy X) engineered for high molten fluoride/chloride salt corrosion resistance.
                    </li>
                    <li>
                        <strong>First-of-a-Kind (FOAK) Support:</strong> Rapid prototyping and engineering development to accelerate SMR design-to-deployment timelines.
                    </li>
                </ul>
            </div>
        </section>

        <section id="casting-hip-protocol">
            <div class="content-container">
                <h2>Vacuum Precision Casting & HIP Protocol</h2>
                <p>
                    To satisfy the zero-defect mandates of the nuclear industry, ForceBeyond enforces a strict VIM + HIP production protocol:
                </p>
                <blockquote class="my-4 italic">
                    Vacuum Induction Melting (VIM) &rarr; Precision Investment Casting &rarr; Hot Isostatic Pressing (HIP) &rarr; 5-Axis CNC Machining &rarr; 100% NDT (X-Ray/FPI/CMM)
                </blockquote>
                <ul>
                    <li>
                        <strong>VIM Casting:</strong> Melting superalloys in a high-vacuum chamber eliminates dissolved gases, slag, and non-metallic inclusions, ensuring ultra-pure grain structures.
                    </li>
                    <li>
                        <strong>Hot Isostatic Pressing (HIP):</strong> Subjecting cast components to simultaneous high temperature and 15,000+ psi argon pressure "heals" internal microscopic voids, yielding 100% theoretical density.
                    </li>
                    <li>
                        <strong>Audit-Ready Documentation:</strong> Every shipment includes comprehensive NDT inspection reports (Radiographic X-ray, Fluorescent Penetrant Inspection), CMM dimensional maps, and EN 10204 3.1 MTRs tracing parts directly to the raw melt.
                    </li>
                </ul>
            </div>
        </section>

    </div>
</IndividualPageLayout>