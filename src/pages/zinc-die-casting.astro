---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Zinc Die Casting: High-Speed Precision Manufacturing';
const seoTitle = 'Custom Zinc Die Casting Services & ZAMAK Alloy Parts | ForceBeyond';
const seoDescription = 'ForceBeyond delivers custom zinc die casting using ZAMAK 2, ZAMAK 3, ZAMAK 5, and ZA 8 alloys. Featuring high-speed hot-chamber injection, ultra-long tool life, near-net-shape precision, and Tier-1.5 CNC machining and decorative chrome plating.';

const faqs = [
    {
        q: "Why choose Zinc over Aluminum for die casting?",
        a: "Zinc is chosen over aluminum when a part requires superior surface finish for plating, heavier weight/density for a premium feel, thinner wall sections, or extremely tight as-cast tolerances. Furthermore, zinc tooling lasts significantly longer than aluminum tooling due to its lower melting point."
    },
    {
        q: "Can zinc die castings be easily plated?",
        a: "Yes. Zinc (particularly ZAMAK 3 and ZA 8) is highly receptive to a wide variety of finishes. It is widely considered the best die-cast material for high-quality decorative chrome plating."
    },
    {
        q: "Does zinc die casting require secondary machining?",
        a: "Very rarely. The zinc die casting process achieves near-net-shape accuracy, and internal threads can often be cast directly into the part. However, ForceBeyond provides in-house CNC machining for features that require ultra-precise micro-tolerances."
    }
];

// Sources 
const sources = [
    { label: 'International Zinc Association (IZA)', url: 'https://www.zinc.org' },
    { label: 'North American Die Casting Association (NADCA)', url: 'https://www.diecasting.org' },
    { label: 'ASM International: "Selection and Properties of Zinc Die Casting Alloys"', url: 'https://www.asminternational.org' }
];

// Resources 
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];

// Service / Product Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/zinc-die-casting#webpage",
      "url": "https://www.forcebeyond.store/oscar/zinc-die-casting",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      },
      "about": [
        {
          "@type": "Thing",
          "name": "Die casting",
          "sameAs": "https://en.wikipedia.org/wiki/Die_casting"
        },
        {
          "@type": "Thing",
          "name": "Zamak",
          "sameAs": "https://en.wikipedia.org/wiki/Zamak"
        }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/zinc-die-casting#service",
      "name": "High-Speed Precision Zinc Die Casting Services",
      "serviceType": "Custom Zinc Die Casting Services",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "High-Speed Precision Zinc Die Casting",
          "Hot-Chamber Zinc Die Casting Technology",
          "ZAMAK Alloys (ZAMAK 2, ZAMAK 3, ZAMAK 5, ZA 8)",
          "Extended Tooling Life & Fast Production Cycles",
          "Ultra-Thin Wall & Intricate Feature Casting",
          "Premium Decorative Chrome Plating & Surface Finishing",
          "Electromagnetic Shielding (EMI) Components",
          "ISO 9001:2015 Tier-1.5 Manufacturing Integration"
        ]
      },
      "areaServed": [
        { "@type": "Country", "name": "United States" },
        { "@type": "Country", "name": "South Korea" },
        { "@type": "Country", "name": "Taiwan" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Zinc Die Casting Capabilities",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Hot-Chamber Precision Zinc Injection",
              "description": "High-speed automated hot-chamber casting of ZAMAK alloys producing parts from a few grams up to over 100 pounds with extended die life."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Near-Net-Shape Decorative Component Casting",
              "description": "Custom molding capable of casting ultra-thin walls, fine threads, and high-precision as-cast surfaces ideal for decorative plating."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Tier-1.5 Turnkey Plating & Finishing Integration",
              "description": "Seamless in-house secondary processing including 5-axis CNC machining, decorative chrome plating, e-coating, powder coating, and bright finishing."
            }
          }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/zinc-die-casting#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
