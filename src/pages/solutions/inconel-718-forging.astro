---
import Layout from '../../layouts/Layout.astro';

const snapshot = [
	['Material', 'Inconel 718 nickel-based superalloy'],
	['Process', 'Controlled closed-die, ring, or open-die forging'],
	['Performance', 'Strength, fatigue resistance, and oxidation resistance'],
	['Component formats', 'Disks, rings, shafts, and critical load-bearing forms'],
	['Supply model', 'Integrated machining, inspection, and delivery coordination']
];

const decisionFactors = ['Operating temperature and exposure profile', 'Tensile, fatigue, and creep loading requirements', 'Part geometry, section thickness, and grain-flow needs', 'Material specification and traceability requirements', 'Production volume, qualification path, and lead-time target', 'Secondary machining, testing, and documentation scope'];
const properties = [
	['Tensile strength', '≥ 1,275 MPa', '≥ 185 ksi'],
	['0.2% yield strength', '≥ 1,035 MPa', '≥ 150 ksi'],
	['Elongation', '≥ 12%', '≥ 12%'],
	['Hardness', 'Typical 38–44 HRC', 'Typical 38–44 HRC']
];
const routes = [
	{ title: 'Closed-Die Forging', text: 'A repeatable route for complex forms and production volumes where controlled grain flow, near-net geometry, and consistency are central to the program.' },
	{ title: 'Seamless Rings', text: 'For high-integrity ring sections where circumferential grain flow and structural continuity support demanding rotating or pressure-service applications.' },
	{ title: 'Open-Die Forging', text: 'A flexible route for larger cross-sections, shafts, and lower-volume shapes that require robust wrought structure before machining.' }
];
const flow = ['Drawing & specification review', 'Material and route selection', 'Forge planning & qualified sourcing', 'Heat treatment & machining coordination', 'Inspection, NDT & documentation', 'Packaging, logistics & supplier coordination'];
const applications = ['Turbine Disks', 'High-Pressure Shafts', 'Oil & Gas Downhole Tools', 'Critical Aerospace Fasteners'];
const quality = [
	['Material', 'Heat-lot traceability, chemistry, and certification review'],
	['NDT', 'Coordinated ultrasonic, penetrant, or other specified examination'],
	['Testing', 'Mechanical testing aligned to drawing and specification needs'],
	['Documents', 'Inspection records and certificate package assembled for release']
];
const connectedPages = [
	['Investment Casting', '/capabilities'], ['Die Casting', '/capabilities'], ['CNC Machining', '/capabilities'], ['Stainless Steel Casting', '/capabilities'], ['Titanium & Sand Casting', '/capabilities'], ['Request a Quote', '/request-a-quote']
];
const faqs = [
	['What is Inconel 718 forging?', 'Inconel 718 forging shapes a precipitation-hardenable nickel-based superalloy into wrought forms with a controlled grain structure for demanding high-temperature and high-stress service.'],
	['Why choose a forged Inconel 718 component?', 'Forging is selected when a component needs the structural continuity, directional grain flow, and mechanical performance associated with wrought processing. The best route depends on geometry, load path, specification, and volume.'],
	['Which applications use forged Inconel 718?', 'Forged Inconel 718 is commonly considered for aerospace propulsion hardware, high-pressure energy equipment, oil and gas tools, and other components exposed to severe heat, corrosion, or cyclic loads.'],
	['Can ForceBeyond coordinate machining and inspection?', 'Yes. ForceBeyond can coordinate material sourcing, forging, heat treatment, CNC machining, specified testing, documentation, and delivery as an integrated supply program.']
];

const productSchema = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Product',
			'@id': 'https://fbwebdemo.netlify.app/solutions/inconel-718-forging#product',
			name: 'Inconel 718 Forging',
			description: 'Custom forged Inconel 718 components for high-stress, high-temperature industrial applications.',
			material: 'Inconel 718 nickel-based superalloy',
			additionalProperty: [
				{ '@type': 'PropertyValue', name: 'Process', value: 'Closed-die forging, seamless ring forging, and open-die forging' },
				{ '@type': 'PropertyValue', name: 'Result', value: 'High-stress components' },
				{ '@type': 'PropertyValue', name: 'Standards', value: 'AMS 5662, NACE, ASTM' }
			]
		},
		{
			'@type': 'FAQPage',
			'@id': 'https://fbwebdemo.netlify.app/solutions/inconel-718-forging#faq',
			mainEntity: faqs.map(([question, answer]) => ({ '@type': 'Question', name: question, acceptedAnswer: { '@type': 'Answer', text: answer } }))
		}
	]
};
---

<Layout title="Inconel 718 Forging | ForceBeyond" description="Inconel 718 forging support for high-stress components in demanding industrial applications.">
	<script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)}></script>

	<section class="border-b border-white/10 bg-slate-900"><div class="mx-auto grid max-w-7xl gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.15fr_0.85fr] lg:items-end lg:px-8 lg:py-28"><div><p class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">High-performance alloy forging</p><h1 class="mt-4 max-w-4xl text-4xl font-bold tracking-tight text-white sm:text-6xl">Inconel 718 Forging</h1><p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">High-strength forged Inconel 718 components for applications that demand reliable performance under extreme heat, pressure, corrosion, and cyclic loading.</p><div class="mt-9 flex flex-col gap-4 sm:flex-row"><a href="/request-a-quote" class="inline-flex justify-center bg-orange-600 px-6 py-3.5 text-sm font-bold text-white transition hover:bg-orange-500">Request a Quote</a><a href="#material" class="inline-flex justify-center border border-white/30 px-6 py-3.5 text-sm font-bold text-white transition hover:border-orange-500 hover:text-orange-500">View Inconel 718 Material</a></div></div><aside class="border-l-2 border-orange-600 bg-slate-800 p-6 sm:p-8"><p class="text-sm font-bold tracking-[0.18em] text-orange-500 uppercase">Solution Snapshot</p><dl class="mt-6 space-y-4">{snapshot.map(([term, description]) => <div class="border-t border-white/10 pt-4"><dt class="text-sm font-bold text-white">{term}</dt><dd class="mt-1 text-sm leading-6 text-slate-300">{description}</dd></div>)}</dl></aside></div></section>

	<section id="material" class="bg-white py-18 text-slate-900 sm:py-24"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div class="overflow-hidden border border-slate-200"><div class="grid text-center sm:grid-cols-3"><div class="p-7"><p class="text-xs font-bold tracking-[0.16em] text-orange-600 uppercase">Material</p><p class="mt-2 text-xl font-bold">Inconel 718</p></div><div class="border-y border-slate-200 bg-slate-50 p-7 sm:border-x sm:border-y-0"><p class="text-xs font-bold tracking-[0.16em] text-orange-600 uppercase">Process</p><p class="mt-2 text-xl font-bold">Forging</p></div><div class="p-7"><p class="text-xs font-bold tracking-[0.16em] text-orange-600 uppercase">Result</p><p class="mt-2 text-xl font-bold">High-Stress Components</p></div></div></div></div></section>

	<section class="border-y border-white/10 bg-slate-800 py-20"><div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8"><div><p class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">Technical evaluation</p><h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">When Inconel 718 Forging Makes Sense</h2><p class="mt-6 text-lg leading-8 text-slate-300">Inconel 718 forging is a practical path when service conditions and component criticality call for a nickel-based superalloy with a controlled wrought structure. A program review should connect the actual load path, environment, geometry, and qualification requirements before a route is selected.</p></div><div><p class="text-sm font-bold tracking-[0.16em] text-slate-400 uppercase">Common Decision Factors</p><ul class="mt-5 divide-y divide-white/10 border-y border-white/10">{decisionFactors.map((factor, index) => <li class="flex gap-4 py-4 text-slate-100"><span class="font-bold text-orange-500">0{index + 1}</span>{factor}</li>)}</ul></div></div></section>

	<section class="bg-white py-20 text-slate-900"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div class="grid gap-8 border-l-2 border-orange-600 bg-slate-50 p-7 lg:grid-cols-[0.75fr_1.25fr]"><div><p class="text-sm font-bold tracking-[0.18em] text-orange-600 uppercase">Standards & data</p><h2 class="mt-3 text-3xl font-bold">Compliance Framework</h2></div><p class="leading-7 text-slate-600">Programs can be planned against customer-defined requirements and applicable material standards, including AMS 5662, NACE requirements for sour-service applications, and relevant ASTM specifications. Final compliance is determined by the drawing, purchase order, and approved quality plan.</p></div><div class="mt-12 overflow-x-auto"><table class="min-w-full border border-slate-200 text-left"><caption class="caption-top mb-4 text-left text-2xl font-bold">Mechanical Properties <span class="text-slate-500">(Forged & Aged)</span></caption><thead class="bg-slate-900 text-white"><tr><th scope="col" class="px-6 py-4">Property</th><th scope="col" class="px-6 py-4">Metric</th><th scope="col" class="px-6 py-4">Imperial</th></tr></thead><tbody>{properties.map(([property, metric, imperial]) => <tr class="border-t border-slate-200 even:bg-slate-50"><th scope="row" class="px-6 py-4 font-bold">{property}</th><td class="px-6 py-4 text-slate-600">{metric}</td><td class="px-6 py-4 text-slate-600">{imperial}</td></tr>)}</tbody></table><p class="mt-3 text-sm text-slate-500">Reference values only; final requirements depend on product form, heat treatment, and governing specification.</p></div></div></section>

	<section class="border-y border-white/10 bg-slate-900 py-20"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><p class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">Route selection</p><h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">Forging Routes</h2><div class="mt-10 grid gap-5 lg:grid-cols-3">{routes.map((route, index) => <article class="border border-white/15 bg-slate-800 p-7"><p class="text-sm font-bold text-orange-500">0{index + 1}</p><h3 class="mt-8 text-xl font-bold text-white">{route.title}</h3><p class="mt-3 leading-7 text-slate-300">{route.text}</p></article>)}</div></div></section>

	<section class="bg-orange-600 py-16 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><p class="text-sm font-bold tracking-[0.2em] text-orange-100 uppercase">One coordinated program</p><h2 class="mt-3 text-3xl font-bold sm:text-4xl">Integrated Manufacturing Support Flow</h2><div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">{flow.map((step, index) => <div class="flex items-center gap-4 border border-white/30 bg-orange-700/30 p-5"><span class="font-bold text-orange-100">0{index + 1}</span><span class="font-semibold">{step}</span></div>)}</div></div></section>

	<section class="bg-white py-20 text-slate-900"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div class="grid gap-12 lg:grid-cols-2"><div><p class="text-sm font-bold tracking-[0.2em] text-orange-600 uppercase">Applications</p><h2 class="mt-3 text-3xl font-bold">Forged Component Applications</h2><ul class="mt-7 grid gap-3 sm:grid-cols-2">{applications.map((application) => <li class="border border-slate-200 bg-slate-50 p-5 font-bold">{application}</li>)}</ul></div><div><p class="text-sm font-bold tracking-[0.2em] text-orange-600 uppercase">Quality Planning</p><h2 class="mt-3 text-3xl font-bold">Defined Before Production</h2><div class="mt-7 grid gap-px border border-slate-200 bg-slate-200 sm:grid-cols-2">{quality.map(([title, text]) => <div class="bg-white p-5"><h3 class="font-bold">{title}</h3><p class="mt-2 text-sm leading-6 text-slate-600">{text}</p></div>)}</div></div></div></div></section>

	<section class="border-y border-white/10 bg-slate-800 py-20"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><p class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">Explore ForceBeyond</p><h2 class="mt-3 text-3xl font-bold text-white">Connected Network</h2><div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">{connectedPages.map(([title, href]) => <a href={href} class="flex items-center justify-between border border-white/15 bg-slate-900 px-5 py-4 font-bold text-white transition hover:border-orange-500 hover:text-orange-500"><span>{title}</span><span class="flex h-6 w-6 items-center justify-center bg-orange-600 text-sm text-white">→</span></a>)}</div></div></section>

	<section class="bg-white py-20 text-slate-900"><div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr] lg:px-8"><div><p class="text-sm font-bold tracking-[0.2em] text-orange-600 uppercase">Technical FAQs</p><h2 class="mt-3 text-3xl font-bold">Inconel 718 Frequently Asked Questions</h2></div><div class="divide-y divide-slate-200 border-y border-slate-200">{faqs.map(([question, answer]) => <details class="group py-1"><summary class="flex cursor-pointer list-none items-center justify-between gap-6 py-5 text-left text-lg font-bold marker:content-none">{question}<span class="flex h-7 w-7 shrink-0 items-center justify-center border border-slate-300 text-orange-600 transition group-open:rotate-45">+</span></summary><p class="max-w-3xl pb-5 pr-12 leading-7 text-slate-600">{answer}</p></details>)}</div></div></section>
</Layout>
