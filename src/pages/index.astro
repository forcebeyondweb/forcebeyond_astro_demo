---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';

const capabilities = [
	{
		title: 'Investment Casting',
		description: 'Precision investment castings for complex geometries, fine surface finishes, and demanding tolerances.'
	},
	{
		title: 'Die Casting',
		description: 'High-volume aluminum, zinc, and magnesium die-cast components engineered for repeatable performance.'
	},
	{
		title: 'Forging',
		description: 'High-strength forged components built to withstand critical loads, heat, and fatigue.'
	},
	{
		title: 'CNC Machining',
		description: 'Multi-axis CNC machining that delivers production-ready parts with exacting dimensional control.'
	},
	{
		title: 'Stainless Steel Casting',
		description: 'Corrosion-resistant stainless steel castings for severe environments and high-performance applications.'
	},
	{
		title: 'Titanium & Sand Casting',
		description: 'Specialized titanium and sand-casting solutions for robust, application-specific components.'
	}
];

const industries = [
	'Aerospace',
	'Automotive',
	'Construction',
	'Energy',
	'Medical',
	'Marine',
	'Oil & Gas',
	'Chemical Processing'
];

const valuePoints = [
	'One accountable manufacturing partner from quotation through delivery',
	'Process selection based on part performance, volume, and total landed cost',
	'Engineering support that identifies manufacturability risks early',
	'Coordinated sourcing, production, inspection, and logistics across suppliers',
	'Clear communication, traceability, and dependable production follow-through'
];

const qualityAreas = [
	{ number: '01', title: 'Material Control', description: 'Specified materials, certifications, and traceability aligned to your application.' },
	{ number: '02', title: 'Process Planning', description: 'Documented production plans that define critical dimensions and control points.' },
	{ number: '03', title: 'In-Process Inspection', description: 'Checks during production to verify quality before parts advance downstream.' },
	{ number: '04', title: 'Final Verification', description: 'Dimensional, visual, and documentation review before shipment release.' },
	{ number: '05', title: 'Continuous Improvement', description: 'Corrective-action discipline and supplier feedback focused on repeatable results.' }
];

const faqs = [
	{
		question: 'Which manufacturing process is right for my component?',
		answer: 'The right process depends on material, geometry, performance requirements, annual volume, tolerances, and target cost. ForceBeyond reviews these requirements with you to recommend the most practical casting, forging, or machining route.'
	},
	{
		question: 'Can ForceBeyond support prototypes as well as production programs?',
		answer: 'Yes. We support programs from early prototype and design-for-manufacturing review through pilot builds and repeat production, with planning that accounts for your expected production ramp.'
	},
	{
		question: 'What materials can you source and manufacture?',
		answer: 'Our capabilities cover a broad range of ferrous and non-ferrous alloys, including carbon steel, stainless steel, aluminum, titanium, and specialty alloys. Material selection is confirmed against the component’s operating environment and performance needs.'
	},
	{
		question: 'How do you manage quality and part traceability?',
		answer: 'We plan quality requirements at the start of a program, coordinate material and process documentation, and apply in-process and final inspection controls appropriate to the part and its end use.'
	},
	{
		question: 'Can you coordinate machining, finishing, and delivery?',
		answer: 'Yes. ForceBeyond can coordinate secondary machining, finishing, inspection, packaging, and logistics so you receive production-ready components from a single accountable partner.'
	}
];

type Capability = { title: string; description: string };
type QualityArea = { title: string; description: string };
type Faq = { question: string; answer: string };
type HomepageContent = {
	heroEyebrow?: string;
	heroHeadline?: string;
	heroDescription?: string;
	primaryCtaLabel?: string;
	primaryCtaHref?: string;
	secondaryCtaLabel?: string;
	secondaryCtaHref?: string;
	capabilitiesTitle?: string;
	capabilitiesDescription?: string;
	capabilities?: Capability[];
	industriesTitle?: string;
	industriesDescription?: string;
	industries?: string[];
	valueTitle?: string;
	valueDescription?: string;
	valuePoints?: string[];
	qualityTitle?: string;
	qualityDescription?: string;
	qualityClosing?: string;
	qualityAreas?: QualityArea[];
	faqTitle?: string;
	faqDescription?: string;
	faqs?: Faq[];
};

const HOMEPAGE_QUERY = `*[_type == "homepage"][0]{
  heroEyebrow, heroHeadline, heroDescription, primaryCtaLabel, primaryCtaHref, secondaryCtaLabel, secondaryCtaHref,
  capabilitiesTitle, capabilitiesDescription, capabilities[]{title, description},
  industriesTitle, industriesDescription, industries,
  valueTitle, valueDescription, valuePoints,
  qualityTitle, qualityDescription, qualityClosing, qualityAreas[]{title, description},
  faqTitle, faqDescription, faqs[]{question, answer}
}`;

let homepage: HomepageContent | null = null;
if (import.meta.env.PUBLIC_SANITY_PROJECT_ID && import.meta.env.PUBLIC_SANITY_DATASET) {
	try {
		homepage = await sanityClient.fetch<HomepageContent | null>(HOMEPAGE_QUERY);
	} catch (error) {
		console.warn('Sanity homepage content could not be loaded; using local fallback content.', error);
	}
}

const displayedCapabilities = homepage?.capabilities?.length ? homepage.capabilities : capabilities;
const displayedIndustries = homepage?.industries?.length ? homepage.industries : industries;
const displayedValuePoints = homepage?.valuePoints?.length ? homepage.valuePoints : valuePoints;
const displayedQualityAreas = homepage?.qualityAreas?.length ? homepage.qualityAreas : qualityAreas;
const displayedFaqs = homepage?.faqs?.length ? homepage.faqs : faqs;

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: displayedFaqs.map((faq) => ({
		'@type': 'Question',
		name: faq.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: faq.answer
		}
	}))
};
---

<Layout title="ForceBeyond | Precision Metal Components" description="ForceBeyond delivers custom precision cast, forged, and CNC-machined metal components.">
	<script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
	<section class="border-b border-white/10 bg-slate-900">
		<div class="mx-auto grid max-w-7xl gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-end lg:gap-20 lg:px-8 lg:py-32">
			<div>
				<p class="mb-5 text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">{homepage?.heroEyebrow || 'ForceBeyond Manufacturing'}</p>
				<h1 class="max-w-4xl text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">{homepage?.heroHeadline || 'Precision Casting, Forging, and CNC Machining Solutions'}</h1>
				<p class="mt-7 max-w-3xl text-lg leading-8 text-slate-300">{homepage?.heroDescription || 'ForceBeyond manufactures custom metal components for demanding industrial applications. From prototype through full production, our integrated casting, forging, and machining capabilities keep quality, lead times, and supply requirements under control.'}</p>
				<div class="mt-9 flex flex-col gap-4 sm:flex-row">
					<a href={homepage?.primaryCtaHref || '/request-a-quote'} class="inline-flex items-center justify-center rounded-sm bg-orange-600 px-6 py-3.5 text-sm font-bold tracking-wide text-white transition hover:bg-orange-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-400">{homepage?.primaryCtaLabel || 'Request a Quote'}</a>
					<a href={homepage?.secondaryCtaHref || '/capabilities'} class="inline-flex items-center justify-center rounded-sm border border-white/30 px-6 py-3.5 text-sm font-bold tracking-wide text-white transition hover:border-orange-500 hover:text-orange-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-400">{homepage?.secondaryCtaLabel || 'View Capabilities'}</a>
				</div>
			</div>
			<div class="border-l-2 border-orange-600 pl-6 text-slate-300">
				<p class="text-4xl font-bold text-white">One partner.</p>
				<p class="mt-2 text-lg leading-7">From material selection to finished, inspected components.</p>
			</div>
		</div>
	</section>

	<section class="bg-white py-20 text-slate-900 sm:py-24">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="max-w-2xl">
				<p class="text-sm font-bold tracking-[0.2em] text-orange-600 uppercase">What we make</p>
				<h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{homepage?.capabilitiesTitle || 'Manufacturing Capabilities'}</h2>
				<p class="mt-4 text-lg leading-8 text-slate-600">{homepage?.capabilitiesDescription || 'Manufacturing processes selected around your design, performance requirements, and production volume.'}</p>
			</div>
			<div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
				{displayedCapabilities.map((capability, index) => (
					<article class="group border border-slate-200 bg-slate-50 p-7 transition hover:-translate-y-1 hover:border-orange-500 hover:bg-white hover:shadow-xl hover:shadow-slate-900/10">
						<p class="text-sm font-bold tracking-[0.16em] text-orange-600">0{index + 1}</p>
						<h3 class="mt-8 text-xl font-bold text-slate-900">{capability.title}</h3>
						<p class="mt-3 leading-7 text-slate-600">{capability.description}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="border-y border-white/10 bg-slate-800 py-20 sm:py-24">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="max-w-2xl">
				<p class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">Built for demanding applications</p>
				<h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">{homepage?.industriesTitle || 'Industries We Serve'}</h2>
				<p class="mt-4 text-lg leading-8 text-slate-300">{homepage?.industriesDescription || 'Material expertise and reliable production support for critical industrial markets.'}</p>
			</div>
			<div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
				{displayedIndustries.map((industry) => (
					<div class="border border-white/15 bg-slate-900 px-5 py-5 text-center text-sm font-bold tracking-wide text-white transition hover:border-orange-500 hover:text-orange-500">
						{industry}
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="bg-white py-20 text-slate-900 sm:py-24">
		<div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:gap-20 lg:px-8">
			<div>
				<p class="text-sm font-bold tracking-[0.2em] text-orange-600 uppercase">The ForceBeyond difference</p>
				<h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{homepage?.valueTitle || 'Why Manufacturers Choose ForceBeyond'}</h2>
			</div>
			<div>
				<p class="text-lg leading-8 text-slate-600">{homepage?.valueDescription || 'Manufacturing programs rarely depend on one process or one supplier. ForceBeyond provides a disciplined coordination layer between your engineering requirements and qualified production resources, helping teams move from concept to dependable supply with less operational friction.'}</p>
				<ul class="mt-8 space-y-4" role="list">
					{displayedValuePoints.map((point) => (
						<li class="flex gap-4 border-t border-slate-200 pt-4 text-base font-semibold leading-6 text-slate-800">
							<svg class="mt-0.5 h-5 w-5 shrink-0 text-orange-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-8 8a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 1.4-1.4L8 12.59l7.3-7.3a1 1 0 0 1 1.4 0Z" clip-rule="evenodd" /></svg>
							{point}
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<section class="border-y border-white/10 bg-slate-900 py-20 sm:py-24">
		<div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:gap-20 lg:px-8">
			<div>
				<p class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">Built into the process</p>
				<h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">{homepage?.qualityTitle || 'Quality-Driven Manufacturing Support'}</h2>
				<p class="mt-6 text-lg leading-8 text-slate-300">{homepage?.qualityDescription || 'Quality is planned before production begins. We translate drawings, specifications, material needs, and critical-to-function requirements into a coordinated production approach, then keep inspection and documentation aligned as the program advances.'}</p>
				<p class="mt-5 leading-7 text-slate-400">{homepage?.qualityClosing || 'The result is a clearer path from engineering intent to parts that are ready for use, inspection, and delivery.'}</p>
			</div>
			<div class="grid gap-px overflow-hidden border border-white/15 bg-white/15 sm:grid-cols-2">
				{displayedQualityAreas.map((area, index) => (
					<article class="bg-slate-800 p-6 sm:p-7">
						<p class="text-sm font-bold tracking-[0.16em] text-orange-500">{(index + 1).toString().padStart(2, '0')}</p>
						<h3 class="mt-8 text-xl font-bold text-white">{area.title}</h3>
						<p class="mt-3 leading-7 text-slate-300">{area.description}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="bg-white py-20 text-slate-900 sm:py-24">
		<div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr] lg:gap-20 lg:px-8">
			<div>
				<p class="text-sm font-bold tracking-[0.2em] text-orange-600 uppercase">Engineering answers</p>
				<h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{homepage?.faqTitle || 'Frequently Asked Questions'}</h2>
				<p class="mt-5 leading-7 text-slate-600">{homepage?.faqDescription || 'A direct starting point for common questions about our manufacturing support.'}</p>
			</div>
			<div class="divide-y divide-slate-200 border-y border-slate-200">
				{displayedFaqs.map((faq) => (
					<details class="group py-1">
						<summary class="flex cursor-pointer list-none items-center justify-between gap-6 py-5 text-left text-lg font-bold text-slate-900 marker:content-none focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-600">
							{faq.question}
							<span class="flex h-7 w-7 shrink-0 items-center justify-center border border-slate-300 text-orange-600 transition group-open:rotate-45" aria-hidden="true">+</span>
						</summary>
						<p class="max-w-3xl pb-5 pr-12 leading-7 text-slate-600">{faq.answer}</p>
					</details>
				))}
			</div>
		</div>
	</section>
</Layout>
