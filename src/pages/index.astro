</section>
<!-- ========================================== -->
<!-- Section: 供应行业矩阵 Who We Supply -->
<!-- Mobile: 2 columns x 4 rows / Desktop: 4 columns x 2 rows -->
<!-- ========================================== -->
<section id="applications" class="relative z-20 w-full pt-6 sm:pt-8 lg:pt-10 pb-16 sm:pb-20 lg:pb-24 bg-slate-50 border-b border-slate-200 overflow-hidden">
        
    <!-- 标题区 -->
