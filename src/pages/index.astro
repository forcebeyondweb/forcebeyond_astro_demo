        <div class="flex-1 group/accordion lg:hover:flex-[2.5] transition-all duration-500 ease-in-out border border-slate-200 bg-white p-6 sm:p-8 rounded-sm flex flex-col justify-between relative overflow-hidden cursor-pointer shadow-sm min-h-[320px] sm:min-h-[360px] lg:min-h-[450px] sm:col-span-2 lg:col-span-1">
            
