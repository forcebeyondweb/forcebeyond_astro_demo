                    />
                </div>

                <div class="home-capability-overlay lg:group-hover/accordion:bg-slate-950/35"></div>
                <div class="home-capability-gradient"></div>
                
                <div class="relative z-10">
                    <h3 class="home-capability-title">
                        Multi-Axis Machining
                    </h3>
                </div>

                <div class="relative z-10">
                    <p class="home-capability-desc lg:group-hover/accordion:hidden">
                        Tight dimensional control and complex profile finishing for precision metal parts.
                    </p>
                    
                    <div class="home-capability-list-mobile">
                        <ul class="grid grid-cols-1 gap-3 text-xs sm:text-sm font-black text-white uppercase tracking-wide drop-shadow-md">
                            <li class="flex items-center gap-2">
                                <span class="home-capability-bullet"></span>
                                Multi-Axis CNC Turning
                            </li>
                            <li class="flex items-center gap-2">
                                <span class="home-capability-bullet"></span>
                                Precision Center Milling
                            </li>
                            <li class="flex items-center gap-2">
                                <span class="home-capability-bullet"></span>
                                Surface Finishing Tasks
                            </li>
                        </ul>
                    </div>

                    <div class="home-capability-list-desktop lg:group-hover/accordion:block">
                        <ul class="grid grid-cols-1 md:grid-cols-3 gap-4 text-xs font-black text-white uppercase tracking-wide drop-shadow-md">
                            <li class="flex items-center gap-2">
                                <span class="home-capability-bullet"></span>
                                Multi-Axis CNC Turning
                            </li>
                            <li class="flex items-center gap-2">
                                <span class="home-capability-bullet"></span>
                                Precision Center Milling
                            </li>
                            <li class="flex items-center gap-2">
                                <span class="home-capability-bullet"></span>
