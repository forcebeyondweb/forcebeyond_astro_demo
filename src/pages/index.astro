---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';

const industries = [
    { name: 'Oil & Gas', imageReserved: '[ Industry Image: Oil & Gas Rig / Valve ]' },
    { name: 'Flow Meter', imageReserved: '[ Industry Image: Flow Meter Housing ]' },
    { name: 'Aerospace', imageReserved: '[ Industry Image: Aerospace Structural Component ]' },
    { name: 'Automotive', imageReserved: '[ Industry Image: Automotive Powertrain Part ]' }
];

const premiumMaterials = [
    { name: 'Titanium Alloy', symbol: 'Ti' },
    { name: 'Nickel Alloy (Superalloy)', symbol: 'Ni' },
    { name: 'Stainless Steel', symbol: 'Fe' },
    { name: 'Cobalt Alloy', symbol: 'Co' }
];

type HomepageContent = {
    heroDescription?: string;
};

const HOMEPAGE_QUERY = `*[_type == "homepage"][0]{ heroDescription }`;

let homepage: HomepageContent | null = null;
try {
    homepage = await sanityClient.fetch<HomepageContent | null>(HOMEPAGE_QUERY);
} catch (error) {
    console.warn('Sanity content fetch skipped. Rendering optimized structural layouts.');
}
---

<Layout title="ForceBeyond | Tier 1.5 Global Supply Chain Partner" description="Precision Built. Globally Sourced. Specialists in Precision Casting, Forging, and Multi-Axis CNC Machining Solutions.">
    
   <!-- Section 1：Hero 视觉首屏 -->
<section 
    id="hero" 
    class="sticky top-0 z-10 flex h-[calc(100vh-5rem)] w-full items-center justify-center overflow-hidden bg-slate-950 px-6 sm:px-12"
>
    <div class="absolute inset-0 z-0">
        <!-- 真实图片背景 -->
        <img 
            src="/oscar/media/machining.png" 
            alt="CNC machining precision metal components for global manufacturing supply chain" 
            title="CNC Machining Precision Metal Components"
            class="w-full h-full object-cover opacity-100"
            loading="eager"
            decoding="async"
        />
        
        <!-- 遮罩：保证文字清晰，同时保留图片亮度 -->
        <div class="absolute inset-0 bg-slate-950/25"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-slate-950/10 via-slate-950/10 to-slate-950/40"></div>
    </div>

    <!-- 悬浮之上的文字标题 -->
    <div class="relative z-10 w-full max-w-6xl mx-auto text-center px-2 sm:px-6 space-y-6 sm:space-y-8"> 
        
        <h1 class="mx-auto max-w-6xl text-[3.35rem] sm:text-6xl lg:text-7xl xl:text-[5.25rem] font-black tracking-[-0.04em] text-white uppercase leading-[0.9] drop-shadow-lg">
            <!-- Mobile: 4 lines -->
            <span class="block sm:hidden">Globally</span>
            <span class="block sm:hidden">Sourced</span>
            <span class="block sm:hidden">Precision</span>
            <span class="block sm:hidden">Built</span>

            <!-- Tablet/Desktop: 2 lines -->
            <span class="hidden sm:block">Globally Sourced</span>
            <span class="hidden sm:block whitespace-nowrap">
                Precision Built
            </span>
        </h1>

        <p class="text-sm sm:text-base lg:text-lg font-bold tracking-[0.16em] sm:tracking-[0.22em] text-amber-400 uppercase drop-shadow-md"> 
            Tier 1.5 Global Supply Chain Partner 
        </p>  

        <p class="mx-auto max-w-3xl text-base sm:text-xl lg:text-2xl leading-7 sm:leading-8 text-slate-100 font-medium tracking-normal drop-shadow-md"> 
            Custom metal components delivered with
            <span class="hidden sm:inline"><br /></span>
            precision, speed, and supply confidence.
        </p> 
    </div>
</section>


    
    <style>
        .no-scrollbar::-webkit-scrollbar {
            display: none; /* Safari and Chrome */
        }
        .no-scrollbar {
            -ms-overflow-style: none;  /* IE and Edge */
            scrollbar-width: none;  /* Firefox */
        }
    </style>

    <script>
        function initIndustrySlider() {
            const marqueeWindow = document.getElementById('marquee-window');
            const btnPrev = document.getElementById('slide-prev');
            const btnNext = document.getElementById('slide-next');

            if (!marqueeWindow || !btnPrev || !btnNext) return;

            const getScrollStep = () => {
                const firstCard = marqueeWindow.querySelector('.industry-card');
                if (firstCard) {
                    return firstCard.clientWidth + 24; 
                }
                return 300;
            };

            btnNext.onclick = () => {
                marqueeWindow.scrollLeft += getScrollStep();
            };

            btnPrev.onclick = () => {
                marqueeWindow.scrollLeft -= getScrollStep();
            };
        }

        initIndustrySlider();
        document.addEventListener('DOMContentLoaded', initIndustrySlider);
        document.addEventListener('astro:page-load', initIndustrySlider);
    </script>

<!-- Section 3：核心定位 Core Positioning -->
<section id="positioning" class="relative z-20 w-full min-h-[800px] lg:min-h-[920px] xl:min-h-[980px] flex items-center bg-slate-50 overflow-hidden">
    
    <!-- 【铺底背景层】 -->
    <div class="absolute inset-0 z-0">
        <!-- 铸造 / 制造核心图片 -->
        <img 
            src="/oscar/media/casting.webp" 
            alt="ForceBeyond precision casting and manufacturing infrastructure" 
            class="w-full h-full object-cover object-[22%_center] lg:object-[28%_center]"
            loading="lazy"
            decoding="async"
        />
        
        <!-- 横向遮罩：左侧保留图片质感，右侧为文字提供干净背景 -->
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950/35 via-slate-50/75 to-slate-50/95 lg:from-slate-950/15 lg:via-slate-50/82 lg:to-slate-50"></div>
        
        <!-- 顶部轻微羽化，避免与上一段硬切 -->
        <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-slate-50/80 to-transparent pointer-events-none"></div>

        <!-- 底部羽化，避免与下一段硬切 -->
        <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-slate-50 via-slate-50/70 to-transparent pointer-events-none"></div>
    </div>
    
    <!-- 【上方文本内容层】 -->
    <div class="relative z-10 w-full px-6 sm:px-12 py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 w-full">
        
        <!-- 左侧留给图片主体 -->
        <div class="hidden lg:block lg:col-span-6"></div>

        <!-- 右侧文字 -->
        <div class="col-span-11 lg:col-span-6 space-y-6 lg:pl-12 backdrop-blur-xs lg:backdrop-blur-none p-6 lg:p-0 rounded-sm bg-slate-50/60 lg:bg-transparent">
                
                <h2 class="text-3xl font-black tracking-tight text-[#0082D6] sm:text-4xl lg:text-5xl leading-tight drop-shadow-xs">
                    Tier 1.5 Strategic Partner
                </h2>

                <p class="text-lg sm:text-xl leading-8 text-slate-700 font-medium">
                    ForceBeyond occupies a precise structural layer. 
                    <strong class="text-slate-900 font-semibold">Tier 1.5 manufacturing partner</strong>
                    — bringing streamlined quote turnaround speeds alongside deep technical engineering support. We shoulder initial layout qualification hazards and synchronize high-complexity multi-facility delivery tasks across international pipelines.
                </p>

                <div class="border-l-4 border-[#0082D6] pl-4 text-lg sm:text-xl leading-8 text-slate-700 font-medium space-y-1.5">
                    <div>• Direct Accountability Matrix</div>
                    <div>• Early Stage DFM Friction Mitigation</div>
                </div>

            </div>
        </div>
    </div>
</section>

    <!-- Section 4：质量与背书 Quality Verification (加入顶部羽化过渡与底色接轨，彻底消除拼接痕迹) -->
    <section id="quality" class="relative z-20 w-full min-h-[800px] lg:min-h-[920px] xl:min-h-[980px] flex items-center bg-slate-50 overflow-hidden">
        
        <!-- 【铺底背景层】 -->
        <div class="absolute inset-0 z-0">
