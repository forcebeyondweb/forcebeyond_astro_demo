---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Materials & Alloy Technical Specifications';
const seoTitle = 'Materials & Alloy Technical Specifications | ForceBeyond';
const seoDescription = 'Technical specifications, mechanical properties, and manufacturing capabilities for superalloys, titanium, stainless steel, and non-ferrous metals.';

const faqs = [
    {
        q: "What certifications are provided with ForceBeyond's materials?",
        a: "Every material processed receives Certified Material Test Reports (MTRs) with full EN 10204 3.1 certification tracing chemical composition, tensile strength, yield strength, and elongation back to the original heat lot."
    },
    {
        q: "How does ForceBeyond prevent alloy mix-ups during manufacturing?",
        a: "We utilize Positive Material Identification (PMI) via X-ray fluorescence (XRF) and optical emission spectrometry (OES) to ensure zero alloy mix-ups across all processing stages."
    }
];

// Sources
const sources = [
    { label: 'ISO 9001:2015 Quality Management Systems Requirements', url: 'https://www.iso.org' },
    { label: 'AS9100 Rev D Quality Management Systems - Aviation, Space & Defense', url: 'https://www.sae.org' },
    { label: 'IATF 16949 Automotive Quality Management Standard', url: 'https://www.iatfglobaloversight.org' },
    { label: 'EN 10204 Metallic Products - Types of Inspection Documents', url: 'https://www.iso.org' },
    { label: 'ASTM E192 Standard Reference Radiographs for Investment Steel Castings', url: 'https://www.astm.org' },
    { label: 'ASTM E1417 Standard Practice for Liquid Penetrant Testing', url: 'https://www.astm.org' }
];

// Resources
// Resources
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];
// Page Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/materials-technical-specs#webpage",
      "url": "https://www.forcebeyond.store/oscar/materials-technical-specs",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      }
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/materials-technical-specs#service",
      "name": "Engineered Metal Alloy Material Selection & Validation",
      "serviceType": "Metallurgical Verification & Precision Alloy Processing",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "Superalloys & Exotic Metals (Inconel, Hastelloy, CoCrMo)",
          "Titanium Alloys (Ti-6Al-4V, Ti-6Al-4V ELI, Grade 2)",
          "Stainless & Carbon Steels (304/316L, 17-4 PH, Duplex 2205/2507, 4140)",
          "Non-Ferrous Aluminum & Copper Alloys (A356-T6, A380, ECO BRASS®)",
          "EN 10204 3.1 Material Test Reports & NDT Quality Verification"
        ]
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Material Portfolio & Technical Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Superalloys & High-Temperature Alloys",
              "description": "Inconel 718/625, Hastelloy X, and CoCrMo for extreme thermal creep up to 1,800°F (980°C)."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Titanium Alloy Components",
              "description": "Lightweight, biocompatible Ti-6Al-4V and Ti-6Al-4V ELI for aerospace and medical applications."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Stainless Steel & Duplex Alloys",
              "description": "Corrosion-resistant 304/316L, 17-4 PH, and Duplex 2205/2507 for subsea, industrial, and fluid handling."
            }
          }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/materials-technical-specs#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<IndividualPageLayout
    title={seoTitle}
    description={seoDescription}
    schema={pageSchema}
    pageTitle={pageTitle}
    heroImage="/oscar/media/precision-cnc-machining-metal-manufacturing-workshop-hero.webp"
    heroImageAlt="Precision CNC milling machine cutting a metal component in a modern manufacturing workshop with automated equipment and digital controls."
    faqSectionTitle="Frequently Asked Questions"
    faqItems={faqs}
    ctaTitle="Select the Optimal Alloy for Your Component"
    ctaDescription="Partner with our metallurgical team for complete alloy validation, raw melt tracing, and precision material testing tailored to your application."
    sourcesTitle="Sources"
    sourcesList={sources}
    resourcesTitle="Our Internal Resources for Die Casting, Investment casting, Forging and Sand Casting"
    resourcesList={internalResources}
>

    <div slot="full-width" class="individual-content">

        <section id="overview">
            <div class="content-container">
                
                <h2>Materials & Technical Specifications: Engineered Metal Alloys</h2>

                <div class="grid gap-10 lg:grid-cols-2 lg:items-center mt-6">
                    <div>
                        <p>
                            At ForceBeyond, material selection dictates component performance. Operating under strict ISO 9001:2015, AS9100 Rev D, and IATF 16949 quality systems, we pour, forge, and machine a broad spectrum of high-performance metals engineered to withstand severe thermal stress, extreme mechanical fatigue, and aggressive chemical environments.
                        </p>
                        <p>
                            Whether your application demands low-density structural titanium for aerospace airframes, high-nickel superalloys for SMR nuclear reactor loops, or corrosion-resistant duplex stainless steel for subsea petroleum extraction, ForceBeyond provides complete metallurgical validation from raw melt to final CMM inspection.
                        </p>
                    </div>
                    <div class="relative">
                        <div class="overflow-hidden">
                            <img
                                src="/oscar/media/materials-technical-specs-overview-4k.webp"
                                alt="Engineered metal alloy billet and precision-machined component."
                                class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500"
                            />
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section id="alloy-portfolio">
            <div class="content-container">
                <h2>Complete Material Portfolio & Engineering Guides</h2>
                <p>
                    Explore our detailed alloy specifications, mechanical properties, and process compatibility across our four core material families:
                </p>
                <div class="content-table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th scope="col">Alloy Category</th>
                                <th scope="col">Key Material Grades</th>
                                <th scope="col">Primary Performance Attributes</th>
                                <th scope="col">Industry Applications</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <th scope="row">Superalloys & Exotic Metals</th>
                                <td>Inconel 718/625, Hastelloy X, CoCrMo</td>
                                <td>Extreme thermal creep resistance up to 1,800°F (980°C); immunity to hot corrosion and oxidation.</td>
                                <td>Aerospace Turbines, SMR Nuclear, Medical Implants.</td>
                            </tr>
                            <tr>
                                <th scope="row">Titanium Alloys</th>
                                <td>Ti-6Al-4V (Grade 5), Ti-6Al-4V ELI, Grade 2</td>
                                <td>High strength-to-weight ratio, excellent fatigue resistance, and non-magnetic biocompatibility.</td>
                                <td>Flight Actuators, Deepwater Drilling, Surgical Tools.</td>
                            </tr>
                            <tr>
                                <th scope="row">Stainless & Carbon Steel</th>
                                <td>304/316L, 17-4 PH, Duplex 2205/2507, 4140</td>
                                <td>Superior pitting/crevice corrosion resistance, high tensile strength, and excellent wear resistance.</td>
                                <td>Oil & Gas, Fluid Control, Mining Teeth.</td>
                            </tr>
                            <tr>
                                <th scope="row">Aluminum & Copper Alloys</th>
                                <td>A356-T6, A380, ECO BRASS®, C11000 Copper</td>
                                <td>Exceptional thermal/electrical conductivity, low density, and high pressure-tight castability.</td>
                                <td>Data Center Power, EV Automotive, Busbars.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="metallurgical-integrity">
            <div class="content-container">
                <h2>Integrated Metallurgical Integrity & Quality Verification</h2>
                <p>
                    Managing raw metal stock requires strict quality governance. Every material processed under ForceBeyond’s Tier-1.5 Manufacturing Model undergoes comprehensive laboratory verification:
                </p>
                <ul>
                    <li>
                        <strong>Certified Material Test Reports (MTRs):</strong> Full EN 10204 3.1 certification tracing chemical composition, tensile strength, yield strength, and elongation back to the original heat lot.
                    </li>
                    <li>
                        <strong>Positive Material Identification (PMI):</strong> X-ray fluorescence (XRF) and optical emission spectrometry (OES) ensure zero alloy mix-ups.
                    </li>
                    <li>
                        <strong>Phase Balance & Grain Structure Verification:</strong> Microstructural analysis to verify phase ratios (e.g., 50/50 ferrite-austenite in Duplex 2205) and freedom from harmful intermetallic precipitates.
                    </li>
                    <li>
                        <strong>Non-Destructive Testing (NDT):</strong> 100% Radiographic Testing (X-Ray per ASTM E192) and Fluorescent Penetrant Inspection (FPI per ASTM E1417) following Hot Isostatic Pressing (HIP).
                    </li>
                </ul>
            </div>
        </section>

    </div>
</IndividualPageLayout>