---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'A356 Aluminum Casting & T6 Heat Treatment: Precision Lightweight Manufacturing';
const seoTitle = 'A356 Aluminum Casting Services & T6 Heat Treatment | ForceBeyond';
const seoDescription = 'ForceBeyond delivers custom A356 aluminum castings with T6 heat treatment. Featuring scalable production from ounces to 200+ lbs, high strength-to-weight ratio, excellent pressure tightness, and Tier-1.5 CNC machining and finishing.';

const faqs = [
    {
        q: "Can A356 aluminum be used as a substitute for 6061 aluminum?",
        a: "Yes. A356 is frequently used as a cast substitute for 6061 aluminum (which is a wrought/extruded alloy). When A356 undergoes the T6 heat treatment, it achieves mechanical properties that make it a highly cost-effective and structurally sound alternative to machining parts from solid 6061 billet."
    },
    {
        q: "Why is A356 preferred for pump housings and impellers?",
        a: "A356 exhibits excellent pressure tightness and high fluidity during the casting process. This allows for the creation of complex internal geometries (like those found in impellers and fluid housings) without the risk of internal micro-shrinkage or leaks."
    },
    {
        q: "What is the difference between A356 and standard die-cast aluminum alloys (like A380)?",
        a: "While alloys like A380 are excellent for high-speed die casting, A356 (often poured via sand or investment casting) contains less copper and more magnesium. This composition gives A356 far superior corrosion resistance, higher strength (when T6 heat-treated), and significantly better weldability than typical die-cast alloys."
    }
];

// Sources 
const sources = [
    { label: 'American Foundry Society: "Metal Casting"', url: 'https://www.afsinc.org' },
    { label: 'ASM International: "Aluminum and Aluminum Alloys"', url: 'https://www.asminternational.org' }
];

// Resources 
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];

// Service / Product Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/a356-aluminum-casting#webpage",
      "url": "https://www.forcebeyond.store/oscar/a356-aluminum-casting",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      },
      "about": [
        {
          "@type": "Thing",
          "name": "A356 aluminum alloy",
          "sameAs": "https://en.wikipedia.org/wiki/Aluminium_alloy"
        },
        {
          "@type": "Thing",
          "name": "T6 heat treatment",
          "sameAs": "https://en.wikipedia.org/wiki/Precipitation_hardening"
        }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/a356-aluminum-casting#service",
      "name": "A356 Aluminum Casting & T6 Heat Treatment Services",
      "serviceType": "Custom A356 Aluminum Casting Services",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "A356 Aluminum Casting",
          "T5 & T6 Heat Treatment Processing",
          "Solution Heat Treating & Artificial Aging",
          "Scalable Production from Ounces to 200+ Pounds",
          "Pressure-Tight Fluid Control & Impeller Castings",
          "Tier-1.5 Cast-to-Machine & Surface Finishing Integration",
          "ISO 9001:2015 Quality Management Systems"
        ]
      },
      "areaServed": [
        { "@type": "Country", "name": "United States" },
        { "@type": "Country", "name": "South Korea" },
        { "@type": "Country", "name": "Taiwan" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "A356 Aluminum Casting Capabilities",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "High-Strength A356 Casting",
              "description": "Scalable production of complex, thin-walled A356 aluminum components ranging from low-volume runs to thousands of parts up to 200+ lbs."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Controlled T6 Heat Treatment",
              "description": "Two-step thermal processing involving solution heat treating, rapid quenching, and artificial aging to maximize yield strength and hardness."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Tier-1.5 Cast-to-Machine Integration",
              "description": "Complete turnaround under one roof including 5-axis CNC machining, e-coating, anodizing, powder coating, and shot blasting."
            }
          }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/a356-aluminum-casting#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
