---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Titanium Aerospace Casting: AS9100-Certified Flight-Critical Components';
const seoTitle = 'Titanium Aerospace Casting | Vacuum Investment | ForceBeyond';
const seoDescription = 'AS9100-certified titanium aerospace casting services for Ti-6Al-4V components. Utilizing vacuum induction melting down to 10⁻⁴ torr to eliminate alpha-case contamination. Global manufacturing hubs across USA, South Korea, and Taiwan with full NDT and HIP processing.';
const faqs = [
    {
        q: "Can cast titanium be used for rotating engine parts?",
        a: "Yes. When produced via VIM and treated with HIP, cast titanium turbine blades and fan components meet the fatigue requirements for many non-primary rotating applications, offering a significant weight and cost advantage over forged parts."
    },
    {
        q: "What is the thinnest wall section you can achieve?",
        a: "Through our specialized investment casting process, we can achieve wall thicknesses as low as 0.060 inches (1.5mm), depending on the overall part geometry and alloy."
    }
];

// Sources 
const sources = [
    { label: 'American Foundry Society: "Metal Casting"', url: 'https://www.afsinc.org' },
    { label: 'Forging Industry Association: "Forging Industry"', url: 'https://www.forging.org' },
    { label: 'efunda. “Sand Casting“', url: 'https://www.efunda.com/processes/metal_processing/sand_casting_intro.cfm' },
    { label: 'The Investment Casting Institute. “What is Investment Casting?“',url:'https://www.investmentcasting.org/what-is-investment-casting.html'},
    { label: 'ASM International. “Inconel 718 Alloy“', url: 'https://www.asminternational.org/materials-resources/alloy-database/technical-bulletin/inconel-718-alloy' }
];

// Resources 
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];
// Service / Product Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/titanium-aerospace-casting#webpage",
      "url": "https://www.forcebeyond.store/oscar/titanium-aerospace-casting",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      },
      "about": [
        {
          "@type": "Thing",
          "name": "Titanium",
          "sameAs": "https://en.wikipedia.org/wiki/Titanium"
        },
        {
          "@type": "Thing",
          "name": "Investment casting",
          "sameAs": "https://en.wikipedia.org/wiki/Investment_casting"
        },
        {
          "@type": "Thing",
          "name": "Aerospace engineering",
          "sameAs": "https://en.wikipedia.org/wiki/Aerospace_engineering"
        }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/titanium-aerospace-casting#service",
      "name": "Precision Titanium Aerospace Casting Services",
      "serviceType": "Titanium Aerospace Casting Services",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "Titanium Aerospace Casting",
          "Vacuum Induction Investment Casting",
          "Ti-6Al-4V Alloy Casting",
          "Alpha-Case Contamination Mitigation (10^-4 Torr)",
          "Hot Isostatic Pressing (HIP)",
          "Non-Destructive Testing (NDT)",
          "AS9100 Rev D Quality Management",
          "Fuselage, Airframe & Turbine Components"
        ]
      },
      "areaServed": [
        { "@type": "Country", "name": "United States" },
        { "@type": "Country", "name": "South Korea" },
        { "@type": "Country", "name": "Taiwan" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Titanium Aerospace Casting Capabilities",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Deep-Vacuum Vacuum Induction Melting (VIM)",
              "description": "Executing complex mold pours within a ultra-pure 10^-4 torr vacuum chamber to completely prevent oxygen pick-up and eliminate structural alpha-case defects."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Hot Isostatic Pressing & Micro-Porosity Elimination",
              "description": "Post-cast high-pressure thermomechanical HIP processing designed to close internal voids, consolidate micro-porosity, and guarantee flight-critical fatigue resilience."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Tier-1.5 Finish-Machined Aerospace Supply",
              "description": "Consolidating near-net-shape titanium vacuum investment casting with precise 5-axis finish CNC machining, complete coordinate measuring machine (CMM) mapping, and exhaustive NDT validation."
            }
          }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/titanium-aerospace-casting#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<IndividualPageLayout
    title={seoTitle}
    description={seoDescription}
    schema={pageSchema}
    pageTitle={pageTitle}
    heroImage="/oscar/media/aerospace-jet-engine-turbine-fan-hero.webp"
    heroImageAlt="aerospace-jet-engine-turbine-fan-hero"
    faqSectionTitle="FAQ: Aerospace Titanium Machining"
    faqItems={faqs}
    ctaTitle=""
    ctaDescription=""
    sourcesTitle="Sources"
    sourcesList={sources}
    resourcesTitle="Our Internal Resources for Die Casting, Investment casting, Forging and Sand Casting"
    resourcesList={internalResources}
>

    <div slot="full-width" class="individual-content">

        <section id="overview" >
            <div class="content-container">
                
                <h2>Titanium Aerospace Casting: AS9100-Certified Flight-Critical Components</h2>

                <div class="grid gap-10 lg:grid-cols-2 lg:items-center mt-6">
                    <div>
                        <p>
                            ForceBeyond provides high-integrity <a href="/oscar/titanium-aerospace-casting" class = "highlight-link">Titanium Aerospace Casting</a> for propulsion, structural airframes, 
                            and high-pressure fluid systems. Utilizing <strong>Vacuum Induction Melting (VIM)</strong> and <strong>Hot Isostatic Pressing (HIP)</strong>, 
                            we deliver cast components that meet the rigorous <strong>AMS 4991</strong> and <strong>ASTM B367</strong> standards. Our Tier-1.5 integrated 
                            model allows for the production of complex, thin-walled geometries that reduce assembly weight while 
                            maintaining the structural reliability required for modern aerospace platforms.
                        </p>
                    </div>

                    <div class="relative">
                        <div class="overflow-hidden">
                            <img
                                src="/oscar/media/titanium-turbine-blade-jet-engine-aerospace-4k.webp"
                                alt="Precision-machined titanium turbine blade for jet engine and aerospace applications on a fully white background."
                                class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500"
                            />
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section id="special-application" >
            <div class="content-container">
                <h2>Aerospace Application Specialization</h2>
                    <p>
                        We specialize in components where geometric complexity makes forging or machining from solid billet cost-prohibitive. 
                        Our co-owned AS9100 facilities ensure total traceability for every flight-critical part.
                    </p>
                    <ul>
                        <li>
                            <strong>Engine & Propulsion:</strong>Fan frames, compressor housings, Titanium Turbine Blades, and exhaust nozzles.
                        </li>
                        <li>
                            <strong>Environmental Control Systems (ECS):</strong>Complex valve bodies, bleed-air ducting, and manifold assemblies.
                        </li>
                        <li>
                            <strong>Structural Components: </strong>Wing-tip ribs, door frames, and nacelle hardware.
                        </li>
                        <li>
                            <strong>Fuel & Hydraulic Systems:</strong>High-pressure pump housings and fuel control bodies.
                        </li>
                    </ul>
                
            </div>
        </section>

        <section id="technical-authority" >
            <div class="content-container">
                <h2>Engineering Excellence: The VIM + HIP Protocol</h2>
                
                <p>
                    ForceBeyond utilizes a specific metallurgical protocol to guarantee that cast components 
                    achieve the isotropic strength and internal soundness required for aerospace service.
                </p>

                <h3>Vacuum Induction Melting (VIM)</h3>
                <p>
                    Titanium’s extreme affinity for oxygen requires a total vacuum environment during the melt. Our VIM process ensures 
                    zero “Alpha-Case” contamination, preserving the material’s ductility and fatigue resistance throughout the solidification phase.
                </p>
                <h3>
                    Hot Isostatic Pressing (HIP)
                </h3>
                <p>
                    Mandatory for all flight-critical hardware, HIP processing subjects castings to simultaneous high temperature and inert gas pressure. 
                    This collapses internal micro-shrinkage and gas porosity, transforming the as-cast structure into a fully 
                    dense material with mechanical properties approaching wrought levels.
                </p>
            </div>
        </section>


        <section id="standard-and-inspection" >
            <div class="content-container">
                <h2>Aerospace Casting Standards & Inspection</h2>
                
                <p>
                    Our Tier-1.5 oversight ensures that every component passes the most stringent nondestructive testing (NDT) 
                    protocols required by global aerospace primes and defense contractors.
                </p>
                <div class="content-table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th scope="col">Standard</th>
                                <th scope="col">Description</th>
                                <th scope="col">Application</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <th scope="row">AMS 4991</th>
                                <td>Titanium Alloy Castings (6Al-4V)</td>
                                <td>Primary aerospace investment casting spec.</td>
                            </tr>
                            <tr>
                                <th scope="row">ASTM B367</th>
                                <td>Titanium & Titanium Alloy Castings</td>
                                <td>General engineering and industrial aerospace.</td>
                            </tr>
                            <tr>
                                <th scope="row">AMS 2175</th>
                                <td>Classification of Castings</td>
                                <td>Standard for radiographic and visual inspection levels.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <h3>Rigorous Quality Verification</h3>
                <ul>
                    <li>
                        <strong>Radiographic Inspection (X-Ray):</strong>100% verification of internal soundness to Grade A standards.
                    </li>
                    <li>
                        <strong>Fluorescent Penetrant Inspection (FPI):</strong>Detection of surface-level discontinuities post-machining.
                    </li>
                    <li>
                        <strong>Mechanical Testing:</strong>Destructive and non-destructive testing of accompanying test coupons from the same melt lot.
                    </li>
                </ul>
            </div>
        </section>


        <section id="inspection" >
            <div class="content-container">
                <h2>Multi-Process Optimization: Integrated Solutions</h2>
                
                <p>
                   ForceBeyond provides the technical flexibility to pivot between manufacturing methods based on your project’s 
                   lifecycle and structural requirements.
                </p>
                <h3>
                    Finish Precision: <a href="/oscar/aerospace-titanium-machining" class="highlight-link">Aerospace Titanium Machining</a>
                </h3>
                <p>
                    All aerospace castings are finished in our co-owned CNC centers to achieve the plus or minus 0.005mm tolerances 
                    required for mating surfaces. This integrated “Cast-to-Finish” approach reduces supply chain risk.
                </p>
                <h3>
                    High-Load Alternative: <a href="/oscar/titanium-aerospace-forging" class="highlight-link">Titanium Aerospace Forging</a>
                </h3>
                <p>
                    For structural parts experiencing extreme unidirectional stress (like wing spars), our <a href="titanium-aerospace-forging" class="highlight-link">Titanium Forging Hub</a> 
                    provides the directional grain flow required for maximum fatigue life.
                </p>

            </div>
        </section>

        <section id="request-quote">
            <div class="content-container">
                <h2>Request an Aerospace Casting Quote</h2>
                
                <p>
                    <strong>Streamline Your Aerospace Supply Chain with Direct Tier-1.5 Oversight.</strong>                
                </p>
                <p>Please provide the following for our engineering review:</p>
                <ul>
                    <li>
                        <strong>Technical Drawings:</strong>(Include NDT requirements and critical dimensions)
                    </li>
                    <li>
                        <strong>Material Specification:</strong>(e.g., AMS 4991, Ti-6Al-4V)
                    </li>
                    <li>
                        <strong>Quality Requirements:</strong>(Specify X-Ray and FPI inspection levels)
                    </li>
                    <li>
                        <strong>Estimated Annual Usage (EAU):</strong>To assist in production planning and tooling optimization.
                    </li>
                </ul>
            </div>
        </section>
    </div>
</IndividualPageLayout>