---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Inconel 625 Forging: Superior Corrosion & Fatigue Resistance';
const seoTitle = 'Inconel 625 Forging: Superior Corrosion & Fatigue Resistance';
const seoDescription = 'AS9100 certified Inconel 625 forging for Nuclear SMR and subsea applications. Utilizing VIM and HIP across our USA, South Korea, and Taiwan facilities.';
const faqs = [
    {
        q: "When should I choose 625 over 718 for a forging?",
        a: "Choose Inconel 625 when your primary concern is corrosion or oxidation in harsh environments (like seawater or acids). Choose Inconel 718 when you need maximum mechanical strength and hardness for rotating parts like turbine disks."
    },
    {
        q: "How does ForceBeyond manage the global supply of 625?",
        a: "We maintain a strategic billet inventory across our US and Asian hubs. This “Tri-Regional” presence allows us to bypass mill backlogs and deliver forged 625 components in <strong>12–16 weeks</strong>, compared to the industry average of 40+ weeks."
    }
];

// Sources 
const sources = [
    { label: 'American Foundry Society: "Metal Casting"', url: 'https://www.afsinc.org' },
    { label: 'Wikipedia: "Investment Casting", "Sand Casting"', url: '' },
    { label: 'Forging Industry Association: "Forging Industry"', url: 'https://www.forging.org' }
];

// Resources 
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];
// Service / Product Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/inconel-625-forging#service",
      "name": "Inconel 625 Forging Services",
      "provider": {
        "@type": "Organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      },
      "description": seoDescription,
      "serviceType": "Inconel 625 Forging Services",
      "areaServed": "United States, South Korea, Taiwan",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Inconel 625 Forging Capabilities",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Closed-Die Forging" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Seamless Rolled Rings" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Open-Die Forging" } }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/inconel-625-forging#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<IndividualPageLayout
    title={seoTitle}
    description={seoDescription}
    schema={pageSchema}
    pageTitle={pageTitle}
    heroImage="/oscar/media/die-casting-investment-casting-forging-cnc-high-precision-machining-title-bar-2.jpg"
    heroImageAlt="Precision forged Inconel 625 component"
    faqSectionTitle="FAQ: Sourcing Inconel 625 Forgings"
    faqItems={faqs}
    ctaTitle="Request an Inconel 625 Technical Consultation"
    ctaDescription="Typical response time: 48 hours for full technical and feasibility review."
    sourcesTitle="Sources"
    sourcesList={sources}
    resourcesTitle="Our Internal Resources for Die Casting, Investment casting, Forging and Sand Casting"
    resourcesList={internalResources}
>
    <div class="individual-content">
        <p><strong>Inconel 625 Forging Key Facts:</strong> Inconel 625 (UNS N06625) is a nickel-chromium-molybdenum alloy forged for extreme corrosion resistance, high fatigue strength, and thermal stability up to 980°C (1,800°F). Ideal for subsea, nuclear SMR, and aerospace applications.</p>
    </div>

    <div slot="full-width" class="individual-content">

        <section id="overview">
            <div class="content-container">
                
                <h2>Inconel 625 Forging: Superior Corrosion & Fatigue Resistance</h2>

                <div class="grid gap-10 lg:grid-cols-2 lg:items-center mt-6">
                    <div>
                        <p>
                            High-precision forged Inconel 625 (UNS N06625) engineered for extreme marine, nuclear SMR, 
                            and chemical processing environments. ForceBeyond provides AS9100-certified forging solutions 
                            utilizing our co-owned global factories to ensure zero-defect integrity.
                        </p>
                        <p>
                            As a specialized component of our <a href="/oscar/superalloy-forging-services" class="highlight-link">Superalloy Forging Services</a>, 
                            ForceBeyond provides precision-engineered <strong>Inconel 625 (UNS N06625)</strong> forgings. 
                            While Inconel 718 is chosen for high-load tensile strength, Inconel 625 is the premier choice for 
                            extreme corrosion resistance and thermal stability up to <strong>980°C (1,800°F)</strong>. 
                            Our forging process refines the grain structure, significantly enhancing the alloy’s resistance 
                            to fatigue and stress-corrosion cracking compared to standard cast components.
                        </p>
                    </div>

                    <div class="relative">
                        <div class="overflow-hidden">
                            <img
                                src="/oscar/media/Precision-seamless-rolled-ring-forging-of-Inconel-718-for-aerospace-engine-at-ForceBeyond-co-owned-facility.jpg"
                                alt="Inconel 625 Precision Forged Component"
                                class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500"
                            />
                        </div>
                    </div>
                </div>

            </div>
        </section>


        <section id="tier-1-5-advantage">
            <div class="content-container">
                <h2>Tier-1.5 Integration: Forging for Severe Environments</h2>
                
                <p>
                    ForceBeyond provides a seamless transition from raw <strong>Inconel 625 Forging</strong> to precision <a href="/oscar/inconel-625-machining" class="highlight-link">Inconel 625 Machining</a>. 
                    Unlike 718, which is forged for peak strength, 
                    Inconel 625 is forged to maximize its resistance to pitting, crevice corrosion, and chloride-ion stress corrosion cracking.
                </p>
                
                <p>
                    By managing the forging reduction and thermal cycles in our USA, South Korea, and Taiwan facilities, 
                    we ensure the niobium and molybdenum remain in solid solution, 
                    providing the ultimate protection for nuclear and subsea infrastructure.
                </p>

                <p>
                    While our forging process provides maximum structural density and fatigue life, components with highly 
                    complex internal passages or thin-walled housings may be better suited for our <a href="/oscar/inconel-625-casting" class="highlight-link">Inconel 625 Casting</a> solutions.
                </p>
            </div>
        </section>


        <section id="why-forged">
            <div class="content-container">
                <h2>Why Forged Inconel 625?</h2>
                
                <p>
                    Inconel 625 is a nickel-chromium-molybdenum alloy with an addition of niobium. 
                    While Inconel 718 is chosen for high-load strength, <strong>Inconel 625 is the premier choice for extreme corrosion resistance</strong>. 
                    Our forging process refines the grain structure, 
                    significantly enhancing the alloy’s resistance to fatigue and stress-corrosion cracking compared to standard cast components.
                </p>

                <h3>The Performance Advantage</h3>
                <ul>
                    <li>
                        <strong>Extreme Corrosion Resistance:</strong> Exceptional protection against pitting, crevice corrosion, and intergranular attack in seawater and acidic environments.
                    </li>
                    <li>
                        <strong>Thermal Stability:</strong> Maintains high toughness and oxidation resistance from cryogenic temperatures up to <strong>980°C (1,800°F)</strong>.
                    </li>
                    <li>
                        <strong>Non-Magnetic Integrity:</strong> Ideal for specialized electronic and subsea sensor housings where magnetic interference must be zero.
                    </li>
                </ul>
            </div>
        </section>


        <section id="specifications" >
            <div class="content-container">
                <h2>Technical Specifications & Standards</h2>
                
                <p>
                    We forge Inconel 625 to meet the most stringent global standards for offshore and nuclear infrastructure.
                </p>

                <h3>Industry Standards Compliance</h3>
                <ul>
                    <li>
                        <strong>Aerospace & Industrial:</strong> AMS 5666, ASTM B446, ASTM B564
                    </li>
                    <li>
                        <strong>Nuclear:</strong> ASME Section III (Safety Class Components)
                    </li>
                    <li>
                        <strong>Oil & Gas:</strong> NACE MR0175 / ISO 15156
                    </li>
                </ul>
                <h3>Typical Mechanical Properties (Forged & Annealed)</h3>
                <div class="content-table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th scope="col">Property</th>
                                <th scope="col">Metric(MPa)</th>
                                <th scope="col">Imperial(ksi)</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <th scope="row">Tensile strength(UTS)</th>
                                <td>827 MPa</td>
                                <td>120 ksi</td>
                            </tr>
                            <tr>
                                <th scope="row">Yield strength(0.2% offset)</th>
                                <td>414 MPa</td>
                                <td>60 ksi</td>
                            </tr>
                            <tr>
                                <th scope="row">Elongation at Break</th>
                                <td>30%</td>
                                <td>30%</td>
                            </tr>
                            <tr>
                                <th scope="row">Density</th>
                                <td>8.44g/cm³</td>
                                <td>0.305lb/in³</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>


        <section id="forging-processes" >
            <div class="content-container">
                <h2>Forging Processes for Inconel 625</h2>
                <p>
                    Our co-owned facilities in the USA, South Korea, and Taiwan specialize in high-integrity 625 components:
                </p>
                <ul>
                    <li>
                        <strong>Closed-Die Forging:</strong> Ideal for high-pressure valve bodies, manifold components, and fuel nozzles.
                    </li>
                    <li>
                        <strong>Seamless Rolled Rings:</strong> Precision rings for Nuclear SMR cooling loops and marine flange assemblies up to 3,500mm.
                    </li>
                    <li>
                        <strong>Open-Die Forging:</strong> Cost-effective for custom blocks, shafts, and large-scale marine hardware.
                    </li>
                </ul>
            </div>
        </section>


        <section id="applications">
            <div class="content-container">
                <h2>Key Applications for Forged 625</h2>   

                <ul>
                    <li>
                        <strong>Nuclear Energy:</strong> Primary reactor cooling loop components and SMR heat exchanger hardware.
                    </li>
                    <li>
                        <strong>Marine & Subsea:</strong> Propeller blades, exhaust systems, and high-pressure subsea valve stems.
                    </li>
                    <li>
                        <strong>Chemical Processing:</strong> Tubing, flare stacks, and reaction vessels handling highly corrosive acids.
                    </li>
                    <li>
                        <strong>Aerospace:</strong> Engine exhaust systems and fuel line bellows.
                    </li>
                </ul>
            </div>
        </section>

        <section id="quality-assurance">
            <div class="content-container">
                <h2>Quality Assurance & NDT Suite</h2>
                <p>
                    Every Inconel 625 forging is subjected to our proprietary <strong>Tier-1.5 Quality Protocol</strong>:
                </p>
                <ul>
                    <li>
                        <strong>Ultrasonic Testing (UT):</strong> 100% volumetric inspection to ensure zero internal inclusions.
                    </li>
                    <li>
                        <strong>Dye Penetrant Inspection (LPI):</strong> Specialized for detecting surface-level porosity in corrosion-critical parts.
                    </li>
                    <li>
                        <strong>Corrosion Testing:</strong> Intergranular corrosion testing (per ASTM G28) upon request to verify alloy purity.
                    </li>
                    <li>
                        <strong>Full Traceability:</strong> Complete heat-lot documentation and certification for critical installations.
                    </li>
                </ul>
            </div>
        </section>
    </div>
</IndividualPageLayout>