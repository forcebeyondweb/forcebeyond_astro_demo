---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Inconel Vacuum Precision Casting: Global Co-Owned Foundries';
const seoTitle = 'Inconel Vacuum Precision Casting: Global Co-Owned Foundries';
const seoDescription = 'AS9100-certified Inconel vacuum investment casting utilizing VIM & 100% HIP for zero-defect aerospace & subsea parts. Global production with 5-axis CNC machining.';
const faqs = [
    {
        q: "Where are ForceBeyond’s Inconel casting foundries located?",
        a: "ForceBeyond co-owns and operates specialized investment casting facilities in the United States, South Korea, and Taiwan, providing a redundant and flexible global supply chain."
    },
    {
        q: "What is the benefit of a co-owned foundry vs. a partner foundry?",
        a: "Co-ownership ensures that ForceBeyond has priority production capacity and direct control over the manufacturing floor, avoiding the markups and communication gaps associated with traditional sourcing brokers."
    },
    {
        q: "Does ForceBeyond provide certified Inconel 718 components?",
        a: "Yes. Every shipment includes full material certification (MTRs), chemical analysis, and NDT (Non-Destructive Testing) reports to ensure compliance with ASTM, AMS, and customer-specific standards."  
    },
    {
        q: "What Inconel grades can be vacuum investment cast?",
        a: "Common grades include Inconel 718, 625, 713C, X-750, and other nickel-based superalloys, subject to component geometry, specification, mechanical-property requirements, and production volume."
    },
    {
        q: "Why is vacuum melting used for Inconel castings?",
        a: "Vacuum melting helps limit oxidation, gas pickup, and contamination when processing nickel-based superalloys containing reactive alloying elements."
    },
    {
        q: "Is HIP required for every Inconel casting?",
        a: "No. HIP is applied when required by the drawing, customer specification, qualification plan, or service conditions. It may be used to reduce internal porosity in critical components."
    },
    {
        q: "What NDT methods are available for Inconel investment castings?",
        a: "Available inspection methods may include radiographic testing, fluorescent penetrant inspection, dimensional inspection, chemical analysis, mechanical testing, and positive material identification."
    },
    {
        q: "Can Inconel castings be delivered fully machined?",
        a: "Yes. ForceBeyond can coordinate casting, heat treatment, HIP where required, 5-axis CNC machining, surface finishing, inspection, and final documentation."
    }
];

// Sources 
const sources = [
    { label: 'American Foundry Society: "Metal Casting"', url: 'https://www.afsinc.org' },
    { label: 'Forging Industry Association: "Forging Industry"', url: 'https://www.forging.org' },
    { label: 'efunda. “Sand Casting“', url: 'https://www.efunda.com/processes/metal_processing/sand_casting_intro.cfm' },
    { label: 'The Investment Casting Institute. “What is Investment Casting?“',url:'https://www.investmentcasting.org/what-is-investment-casting.html'},
    { label: 'ASM International. “Inconel 718 Alloy“', url: 'https://www.asminternational.org/materials-resources/alloy-database/technical-bulletin/inconel-718-alloy' }
];

// Resources 
const internalResources = [
    { label: "Die Casting", url: "/die-casting" },
    { label: "Aluminum Die Casting", url: "/aluminum-die-casting" },
    { label: "Inconel 718 Machining", url: "/inconel-718-machining" },
    { label: "Precision CNC Machining and Secondary Operations", url: "/cnc-machining" }
];
// Service / Product Schema
// Ensure 'faqs' array exists in your frontmatter
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/inconel-vacuum-precision-casting#webpage",
      "url": "https://www.forcebeyond.store/oscar/inconel-vacuum-precision-casting",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      },
      "about": [
        {
          "@type": "Thing",
          "name": "Investment Casting",
          "sameAs": "https://en.wikipedia.org/wiki/Investment_casting"
        },
        {
          "@type": "Thing",
          "name": "Vacuum Induction Melting",
          "sameAs": "https://en.wikipedia.org/wiki/Vacuum_induction_melting"
        },
        {
