          "name": "Hot Isostatic Pressing",
          "sameAs": "https://en.wikipedia.org/wiki/Hot_isostatic_pressing"
        },
        {
          "@type": "Thing",
          "name": "Superalloy",
          "sameAs": "https://en.wikipedia.org/wiki/Superalloy"
        }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/inconel-vacuum-precision-casting#service",
      "name": "Inconel Vacuum Precision Investment Casting Services",
      "serviceType": "Inconel Vacuum Precision Investment Casting Services",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "Inconel Superalloys (Inconel 718, 625, X-750, 600)",
          "Vacuum Induction Melting (VIM)",
          "Hot Isostatic Pressing (HIP)",
          "AS9100D Certification",
          "5-Axis CNC Machining",
          "Aerospace Turbines & Rocket Propulsion",
          "Nuclear SMR & Subsea Hardware"
        ]
      },
      "areaServed": [
        { "@type": "Country", "name": "United States" },
        { "@type": "Country", "name": "South Korea" },
        { "@type": "Country", "name": "Taiwan" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Inconel Vacuum Precision Casting Capabilities",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Inconel Vacuum Investment Casting (VIM)",
              "description": "AS9100-certified VIM casting for high-temperature nickel superalloy components."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Hot Isostatic Pressing (HIP) Densification",
              "description": "100% HIP process to eliminate internal microporosity and ensure maximum structural density."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Multi-Alloy Inconel Casting (718, 625, X-750, 600)",
              "description": "Precision casting across full range of heat-resistant and corrosion-resistant Inconel grades."
            }
          },
          {
