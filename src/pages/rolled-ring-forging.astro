---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Seamless Rolled Ring Forging: High-Strength Circular Components';
const seoTitle = 'Seamless Rolled Ring Forging | Inconel 718 & Titanium Rings';
const seoDescription = 'AS9100-certified seamless rolled ring forging for high-stress aerospace and industrial applications. ForceBeyond produces seam-free rings up to 100+ inches OD with continuous circumferential grain flow in Inconel 718, Titanium, and stainless steel.';
const faqs = [
    {
        q: "How is a seamless rolled ring actually made?",
        a: "The process begins by cutting a cylindrical billet of metal. The billet is heated and 'upset' (compressed flat) before a hole is punched through the center, creating a thick 'donut'. This donut is placed on a ring rolling mill, where internal and external rollers squeeze the walls, simultaneously reducing the wall thickness and expanding the ring's overall diameter until it reaches the targeted size."
    },
    {
        q: "Why is rolled ring forging better than burning a ring out of steel plate?",
        a: "Cutting a ring out of a steel plate leaves an exposed, unidirectional grain structure (imagine cutting a circle out of a piece of wood). Under high rotational stress or pressure, this ring is prone to cracking along those grain lines. Ring rolling forces the grain to flow in a continuous circle, making it vastly stronger and more fatigue-resistant."
    },
    {
        q: "Can ForceBeyond roll rings with profiled or contoured cross-sections?",
        a: "Yes. While many rings are rolled with simple rectangular cross-sections, we can utilize profiled rollers to create complex inner or outer contours (such as tapered walls, steps, or grooves). This brings the ring even closer to its final net shape, further reducing CNC machining time."
    }
];

// Sources 
const sources = [
    { label: 'American Foundry Society: "Metal Casting"', url: 'https://www.afsinc.org' },
    { label: 'Forging Industry Association: "Forging Industry"', url: 'https://www.forging.org' },
    { label: 'efunda. “Sand Casting“', url: 'https://www.efunda.com/processes/metal_processing/sand_casting_intro.cfm' },
    { label: 'The Investment Casting Institute. “What is Investment Casting?“',url:'https://www.investmentcasting.org/what-is-investment-casting.html'},
    { label: 'ASM International. “Inconel 718 Alloy“', url: 'https://www.asminternational.org/materials-resources/alloy-database/technical-bulletin/inconel-718-alloy' }
];

// Resources 
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
