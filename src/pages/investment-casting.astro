---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle ='Investment Casting (Lost-Wax Process): High-Precision, Near-Net-Shape Manufacturing';
const seoTitle = 'Investment Casting Services | Precision Lost-Wax Components';
const seoDescription = 'Custom investment casting (lost-wax process) for intricate near-net-shape metal parts. ForceBeyond utilizes vacuum-cast Inconel 718, titanium, and stainless steel to deliver complex internal coring, 125 RMS finishes, and thin walls down to 0.040".';
const faqs = [
    {
        q: "How does investment casting compare to sand casting?",
        a: "Sand casting uses a reusable wood or metal pattern to pack sand into a two-part mold, making it great for massive, heavy parts. However, the surface finish is rough, and tolerances are loose. Investment casting uses a ceramic shell to achieve incredibly smooth finishes, ultra-tight tolerances, and thin walls, making it the better choice for smaller, highly precise, or complex parts."
    },
    {
        q: "What is the typical minimum wall thickness for an investment casting?",
        a: "Depending on the alloy and the geometry of the part, investment casting can reliably produce wall thicknesses as thin as 0.040 inches (1.0 mm), though standard designs usually target 0.060 inches to 0.125 inches."
    },
    {
        q: "Does ForceBeyond offer rapid prototyping for investment cast parts?",
        a: "Yes. We can utilize 3D-printed wax or SLA patterns to create a ceramic shell and pour rapid prototype castings. This allows your engineering team to physically test the actual cast alloy before committing to the cost of hard aluminum tooling."
    }
];

// Sources 
const sources = [
    { label: 'American Foundry Society: "Metal Casting"', url: 'https://www.afsinc.org' },
    { label: 'Forging Industry Association: "Forging Industry"', url: 'https://www.forging.org' },
    { label: 'efunda. “Sand Casting“', url: 'https://www.efunda.com/processes/metal_processing/sand_casting_intro.cfm' },
    { label: 'The Investment Casting Institute. “What is Investment Casting?“',url:'https://www.investmentcasting.org/what-is-investment-casting.html'},
    { label: 'ASM International. “Inconel 718 Alloy“', url: 'https://www.asminternational.org/materials-resources/alloy-database/technical-bulletin/inconel-718-alloy' }
];

