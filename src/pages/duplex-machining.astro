---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Duplex & Super Duplex Stainless Steel Machining: High-Strength Alloys';
const seoTitle = 'Custom Duplex & Super Duplex CNC Machining Services | ForceBeyond';
const seoDescription = 'ForceBeyond provides specialized CNC machining for Duplex (2205) and Super Duplex (2507, Zeron 100) stainless steel components with near-net casting, heat treatment, and chemical passivation.';

const faqs = [
    {
        q: "Why is Duplex stainless steel so much harder to machine than 316L?",
        a: "Duplex stainless steels have roughly double the yield strength of 316L, meaning it takes significantly more force to shear the metal into a chip. Additionally, Duplex alloys work-harden much faster, generating extreme friction and heat that can quickly destroy standard cutting tools if cutting speeds and feed rates are not perfectly optimized."
    },
    {
        q: "How does ForceBeyond verify the quality of machined Duplex parts?",
        a: "Every machined Duplex component undergoes rigorous quality assurance. We provide 100% CMM inspection for tight tolerances, Positive Material Identification (PMI) to verify alloy composition, Liquid Penetrant Inspection (LPI) for surface integrity, and full Material Test Reports (MTRs) certifying compliance with ASTM standards and NACE MR0175/ISO 15156 for sour gas service."
    },
    {
        q: "Does secondary CNC machining affect the corrosion resistance of Duplex steel?",
        a: "If done incorrectly, yes—excessive heat generation during machining can disrupt the alloy's microstructure or embed free iron on the surface. ForceBeyond uses precise thermal controls during machining, followed by chemical passivation treatments, to ensure the protective chromium-oxide layer is fully restored, preserving maximum corrosion resistance."
    }
];

// Sources 
const sources = [
    { label: 'International Molybdenum Association (IMOA): "Machining Duplex Stainless Steels"', url: 'https://www.imoa.info' },
    { label: 'ASM International: "Properties and Selection: Irons, Steels, and High-Performance Alloys"', url: 'https://www.asminternational.org' },
    { label: 'NACE International / ISO 15156: Materials for use in H2S-containing Environments in Oil and Gas Production', url: 'https://www.nace.org' }
];

// Resources 
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];

// Service / Product Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/duplex-super-duplex-machining#webpage",
      "url": "https://www.forcebeyond.store/oscar/duplex-super-duplex-machining",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      },
      "about": [
        {
          "@type": "Thing",
          "name": "Duplex stainless steel",
          "sameAs": "https://en.wikipedia.org/wiki/Duplex_stainless_steel"
        },
        {
          "@type": "Thing",
          "name": "Machining",
          "sameAs": "https://en.wikipedia.org/wiki/Machining"
        }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/duplex-super-duplex-machining#service",
      "name": "Duplex & Super Duplex Stainless Steel Machining Services",
      "serviceType": "Custom Duplex Alloy CNC Machining",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "5-Axis CNC Milling & Turning of Duplex Stainless Steels",
          "Duplex 2205 (UNS S31803 / S32205)",
          "Super Duplex 2507 (UNS S32750)",
          "Zeron 100 (UNS S32760)",
          "Cast Duplex CD4MCuN (UNS J93370)",
          "High-Pressure Through-Spindle Coolant Delivery",
          "Tier-1.5 Near-Net Casting to CNC Machining Pipeline",
          "NACE MR0175 / ISO 15156 Compliance & Quality Testing"
        ]
      },
      "areaServed": [
        { "@type": "Country", "name": "United States" },
        { "@type": "Country", "name": "South Korea" },
        { "@type": "Country", "name": "Taiwan" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Duplex Machining Capabilities",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Precision CNC Milling & Threading",
              "description": "Rigid multi-axis CNC milling and turning tailored specifically for high-strength Duplex and Super Duplex alloys."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Cast-to-Machine Duplex Solutions",
              "description": "Near-net investment casting combined with in-house CNC finish machining that reduces material waste up to 70%."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Solution Annealing & Quality Assurance",
              "description": "In-house heat treatment for 50/50 ferrite-austenite microstructure preservation, along with CMM, PMI, and LPI testing."
            }
          }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/duplex-super-duplex-machining#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
