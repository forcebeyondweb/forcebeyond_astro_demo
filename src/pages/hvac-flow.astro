---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'HVAC, Fluid & Flow Control Casting & Machining';
const seoTitle = 'HVAC, Fluid & Flow Control Casting & Machining | ForceBeyond';
const seoDescription = 'ForceBeyond supplies pressure-tight, lead-free castings, forgings, and CNC machined valve hardware for HVAC, plumbing, and fluid control industries.';

const faqs = [
    {
        q: "Are ForceBeyond’s brass castings compliant with lead-free plumbing regulations?",
        a: "Yes. We process certified ECO BRASS® (C69300) and silicon bronze alloys that comply 100% with US Safe Drinking Water Act mandates and NSF/ANSI 61 standards."
    },
    {
        q: "Can ForceBeyond supply fully assembled ball valves?",
        a: "Yes. We supply complete sub-assemblies including cast valve bodies, machined stems, stainless balls, PTFE seats, O-rings, and handles—100% pressure-tested and kitted."
    }
];

// Sources
const sources = [
    { label: 'ISO 9001:2015 Quality Management Systems Requirements', url: 'https://www.iso.org' },
    { label: 'NSF/ANSI 61 Drinking Water System Components Standard', url: 'https://www.nsf.org' },
    { label: 'ASTM International: Fluid Control Material & Valve Specifications', url: 'https://www.astm.org' }
];

// Resources
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];

// Page Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/hvac-fluid-flow-control#webpage",
      "url": "https://www.forcebeyond.store/oscar/hvac-fluid-flow-control",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      }
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/hvac-fluid-flow-control#service",
      "name": "HVAC & Fluid Control Component Manufacturing",
      "serviceType": "Fluid Processing Precision Manufacturing",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "Lead-Free ECO BRASS® & Silicon Bronze Casting",
          "Pressure-Tight Investment & Die Casting Solutions",
          "Live-Tool CNC Turning for NPT, BSPT & Metric Threads",
          "100% Pneumatic Air-Under-Water & Helium Decay Leak Testing",
          "Complete Valve Assembly, Sub-Assembly & Kitting"
        ]
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "HVAC & Fluid Control Capabilities",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Lead-Free Plumbing & Valve Hardware",
              "description": "ECO BRASS® and bronze components complying with SDWA mandates and NSF/ANSI 61 standards."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Industrial Fluid Processing Components",
              "description": "316L/304 stainless steel cast and machined valve bodies, pump housings, and chemical mixers."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "HVAC & Pneumatic Enclosures",
              "description": "Lightweight, pressure-tight aluminum die castings for compressor housings and actuator bodies."
            }
          }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/hvac-fluid-flow-control#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<IndividualPageLayout
    title={seoTitle}
    description={seoDescription}
    schema={pageSchema}
    pageTitle={pageTitle}
    heroImage="/oscar/media/industrial-hvac-ductwork-manufacturing-facility-hero.webp"
    heroImageAlt="Wide interior view of a modern industrial HVAC facility with large stainless steel ductwork, production equipment, and workers."
    faqSectionTitle="Frequently Asked Questions"
    faqItems={faqs}
    ctaTitle="Streamline Your HVAC & Fluid Control Manufacturing"
    ctaDescription="Partner with our engineering experts for zero-leakage, pressure-tight castings and fully assembled fluid control solutions."
    sourcesTitle="Sources"
    sourcesList={sources}
    resourcesTitle="Our Internal Resources for Die Casting, Investment casting, Forging and Sand Casting"
    resourcesList={internalResources}
>

    <div slot="full-width" class="individual-content">

        <section id="overview">
            <div class="content-container">
                
                <h2>HVAC, Fluid & Flow Control Casting & Machining</h2>

                <div class="grid gap-10 lg:grid-cols-2 lg:items-center mt-6">
                    <div>
                        <p>
                            ForceBeyond supplies high-precision, pressure-tight castings, forgings, and machined valve hardware for the HVAC, plumbing, commercial refrigeration, and fluid processing industries. Fluid control systems require leak-free performance, smooth internal flow paths, and high corrosion resistance.
                        </p>
                        <p>
                            We pour lead-free Eco Brass®, bronze, 316L stainless steel, and A380 aluminum—utilizing vacuum investment casting, die casting, and high-speed CNC multi-axis turning.
                        </p>
                    </div>
                    <div class="relative">
                        <div class="overflow-hidden">
                            <img
                                src="/oscar/media/industrial-hvac-piping-flow-control-system.webp"
                                alt="Large industrial HVAC mechanical room with orange process piping, insulated metal ducts, valves, pumps, and flow-control equipment."
                                class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500"
                            />
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section id="material-matrix">
            <div class="content-container">
                <h2>Fluid Control Material & Capabilities Matrix</h2>
                <div class="content-table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th scope="col">Material Category</th>
                                <th scope="col">Alloy Grades Offered</th>
                                <th scope="col">Key Fluid Control Benefits</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <th scope="row">Lead-Free Brass & Bronze</th>
                                <td>ECO BRASS® (C69300), C83600</td>
                                <td>Fully compliant with Safe Drinking Water Act (SDWA) standards; excellent machinability and pressure tightness.</td>
                            </tr>
                            <tr>
                                <th scope="row">Austenitic Stainless Steel</th>
                                <td>ASTM A351 CF8M (316 Cast), CF8 (304)</td>
                                <td>Superior chemical and corrosion resistance for industrial fluid mixing, food/dairy, and chemical pumps.</td>
                            </tr>
                            <tr>
                                <th scope="row">Aluminum Alloys</th>
                                <td>A380, A360, A413</td>
                                <td>Lightweight, pressure-tight die castings for HVAC compressor housings and pneumatic valve bodies.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="manufacturing-capabilities">
            <div class="content-container">
                <h2>Precision Valve & Pump Manufacturing Capabilities</h2>
                <ul>
                    <li>
                        <strong>Smooth Internal Flow Paths:</strong> Investment casting yields ultra-smooth surface finishes (125 RMS) that optimize hydraulic efficiency and reduce fluid turbulence.
                    </li>
                    <li>
                        <strong>Precision Threading & Sealing Faces:</strong> Live-tool CNC turning ensures perfect concentricity and true-position threads (NPT, BSPT, Metric).
                    </li>
                    <li>
                        <strong>100% Pressure & Leak Testing:</strong> Pneumatic air-under-water and helium decay testing ensure zero porosity leaks before shipment.
                    </li>
                </ul>
            </div>
        </section>

    </div>
</IndividualPageLayout>