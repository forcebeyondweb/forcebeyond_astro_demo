  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/surface-finishing-protective-coating#webpage",
      "url": "https://www.forcebeyond.store/oscar/surface-finishing-protective-coating",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      },
      "about": [
        {
          "@type": "Thing",
          "name": "Surface finishing",
          "sameAs": "https://en.wikipedia.org/wiki/Surface_finishing"
        },
        {
          "@type": "Thing",
          "name": "Anodizing",
          "sameAs": "https://en.wikipedia.org/wiki/Anodizing"
        }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/surface-finishing-protective-coating#service",
      "name": "Surface Finishing & Protective Coating Services",
      "serviceType": "Metal Surface Treatment & Post-Processing",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "Stainless Steel Chemical Passivation (ASTM A967)",
          "Electropolishing for Medical & Sanitary Components",
          "Type II & Type III Hardcoat Anodizing (MIL-A-8625)",
          "Electroless Nickel Plating (ENP) & Chem Film",
          "E-Coating, Powder Coating & Pre-Treatment Blasting"
        ]
      },
      "areaServed": [
        { "@type": "Country", "name": "United States" },
        { "@type": "Country", "name": "South Korea" },
        { "@type": "Country", "name": "Taiwan" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Surface Finishing Options",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Chemical Treatments & Passivation",
              "description": "Citric/nitric passivation and electropolishing engineered to prevent corrosion and deliver micro-smooth surface profiles."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Anodizing & Conversion Coatings",
              "description": "Type II, Type III Hardcoat Anodizing, and Chem Film treatments providing wear resistance and corrosion protection."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Plating & Applied Barrier Coatings",
              "description": "Electroless Nickel Plating (ENP), E-coating, and powder coating for extreme environmental endurance."
