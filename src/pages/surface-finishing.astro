---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Surface Finishing & Protective Coating Services';
const seoTitle = 'Custom Surface Finishing & Protective Coating Services | ForceBeyond';
const seoDescription = 'ForceBeyond delivers comprehensive surface finishing services for custom castings, forgings, and CNC components, including passivation, electropolishing, Type II/III anodizing, and ENP.';

const faqs = [
    {
        q: "What is the difference between Passivation and Electropolishing for stainless steel?",
        a: "Passivation is a chemical bath (citric or nitric acid) that dissolves free iron from the surface without changing the part's physical dimensions or surface roughness. It focuses purely on restoring corrosion resistance. Electropolishing is an electrochemical process (the opposite of electroplating) that actually removes a microscopic layer of metal (typically 0.0001” to 0.0005”). It levels the surface micro-profile, removing burrs and creating a ultra-smooth, bright, mirror-like finish ideal for sterile sanitary and medical hardware."
    },
    {
        q: "Why is Electroless Nickel Plating preferred over Electroplated Nickel for complex castings?",
        a: "Traditional electroplating relies on electrical current, which causes the plating to build up thickly on outside corners while leaving deep cavities, internal threads, and blind holes under-plated. Electroless Nickel Plating uses a autocatalytic chemical reaction without electrical current, depositing an exact, uniform layer of nickel-phosphorus across every surface of the part, regardless of geometry."
    },
    {
        q: "Does Type III Hardcoat Anodizing affect part dimensions?",
        a: "Yes. Hardcoat anodizing grows the oxide layer into the aluminum material while simultaneously building up on the surface. Typically, 50% of the coating thickness penetrates into the metal and 50% builds up on the surface. For a standard 0.002” (50 micron) hardcoat coating, the surface of the part will increase in dimension by approximately 0.001” per side. Our CNC engineering team accounts for this exact growth during the machining phase prior to anodizing."
    }
];

// Sources
const sources = [
    { label: 'ISO 9001:2015 Quality Management Systems Requirements', url: 'https://www.iso.org' },
    { label: 'ASTM International: Chemical Passivation, Anodizing & Salt Spray Standards', url: 'https://www.astm.org' },
    { label: 'AMS / MIL Specifications for Anodizing and Plating Standards', url: 'https://www.quickseries.com' }
];

// Resources
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];

// Service / Product Schema
const pageSchema = {
