---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Quality Assurance & Certifications: Zero-Defect Manufacturing';
const seoTitle = 'Quality Assurance & AS9100 Certifications | ForceBeyond';
const seoDescription = 'ForceBeyond’s global quality assurance program. Certified to ISO 9001:2015, AS9100 Rev D, and IATF 16949, with Nadcap-compliant special processing for OEMs.';

const faqs = [
    {
        q: "What is the difference between an EN 10204 3.1 and 3.2 Material Test Report (MTR)?",
        a: "A 3.1 MTR is certified by the manufacturer's independent quality representative, confirming that the specific heat lot meets all chemical and mechanical requirements. A 3.2 MTR includes all the data of a 3.1, but is co-signed by an independent third-party inspector (such as Lloyd’s Register or ABS). ForceBeyond standardly provides 3.1 MTRs and can facilitate 3.2 certifications upon request."
    },
    {
        q: "Does ForceBeyond provide AS9102 First Article Inspection (FAI) reports?",
        a: "Yes. For aerospace, defense, and other highly regulated industries, we provide comprehensive AS9102-compliant FAI reports. This includes a complete dimensional 'balloon' drawing mapped to our CMM data, verifying that every single CAD feature has been manufactured to specification."
    }
];

// Sources
const sources = [
    { label: 'AS9100 Rev D Quality Management Systems - Aviation, Space & Defense', url: 'https://www.sae.org' },
    { label: 'ISO 9001:2015 Quality Management Systems Requirements', url: 'https://www.iso.org' },
    { label: 'IATF 16949 Automotive Quality Management System', url: 'https://www.iatfglobaloversight.org' },
    { label: 'Nadcap Accreditation Program for Special Processes', url: 'https://www.pmi.pwc.ca' }
];

// Resources
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];

// Page Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/quality-assurance-certifications#webpage",
      "url": "https://www.forcebeyond.store/oscar/quality-assurance-certifications",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      }
    },
    {
      "@type": "Service",
      "@id": "https://www.forcebeyond.store/oscar/quality-assurance-certifications#service",
      "name": "Quality Assurance & Certification Management",
      "serviceType": "Quality Control & Regulatory Compliance Services",
      "description": seoDescription,
      "provider": {
        "@type": "Organization",
        "@id": "https://www.forcebeyond.store/oscar#organization",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar",
        "knowsAbout": [
          "AS9100 Rev D Aerospace Quality Certification",
          "ISO 9001:2015 Quality Management Systems",
          "IATF 16949 Automotive Quality System",
          "Nadcap Compliant Special Processes",
          "AS9102 First Article Inspection (FAI) & PPAP Submissions",
          "EN 10204 3.1 & 3.2 Material Traceability"
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/quality-assurance-certifications#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<IndividualPageLayout
    title={seoTitle}
    description={seoDescription}
    schema={pageSchema}
    pageTitle={pageTitle}
    heroImage="/oscar/media/die-casting-investment-casting-forging-cnc-high-precision-machining-title-bar-2.jpg"
    heroImageAlt="Quality assurance inspection and CMM dimensional mapping"
    faqSectionTitle="Frequently Asked Questions: Quality Assurance"
    faqItems={faqs}
    ctaTitle="Partner with an AS9100-Certified Quality Leader"
    ctaDescription="Ensure zero-defect manufacturing and complete material traceability for your critical aerospace, automotive, or industrial components."
    sourcesTitle="Sources"
    sourcesList={sources}
    resourcesTitle="Our Internal Resources for Quality and Global Operations"
    resourcesList={internalResources}
>

    <div slot="full-width" class="individual-content">

        <section id="overview">
            <div class="content-container">
                
                <h2>Quality Assurance & Certifications: Zero-Defect Manufacturing</h2>

                <div class="grid gap-10 lg:grid-cols-2 lg:items-center mt-6">
                    <div>
                        <p>
                            At ForceBeyond, quality is not just a final inspection step—it is a proactive, risk-managed discipline integrated into every phase of our Tier-1.5 Manufacturing Model. For OEMs in the aerospace, nuclear energy, medical device, and automotive sectors, component failure carries unacceptable risks. We mitigate that risk by engineering quality into the process before the first pour or forge is ever executed.
                        </p>
                        <p>
                            Operating a unified Quality Management System (QMS) across our global network, we provide Tier-1 and Tier-2 procurement teams with audit-ready transparency, absolute material traceability, and continuous process controls that guarantee zero-defect delivery.
                        </p>
                    </div>
                    <div class="relative">
                        <div class="overflow-hidden">
                            <img
                                src="/oscar/media/quality-assurance-certifications-overview-4k.webp"
                                alt="Quality assurance engineer using precision metrology equipment to inspect metal components."
                                class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500"
                            />
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section id="core-certifications">
            <div class="content-container">
                <h2>Core Quality Management Certifications</h2>
                <p>
                    Our facilities operate under the world’s most stringent regulatory frameworks, ensuring compliance across every major industrial vertical:
                </p>
                <div class="content-table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th scope="col">Certification</th>
                                <th scope="col">Regulated Industry Focus</th>
                                <th scope="col">Key Quality Mandates & Controls</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <th scope="row">AS9100 Rev D</th>
                                <td>Aerospace, Defense, SMR Nuclear</td>
                                <td>Strict risk management, counterfeit parts prevention, and 100% material traceability from raw melt to final assembly.</td>
                            </tr>
                            <tr>
                                <th scope="row">ISO 9001:2015</th>
                                <td>Industrial, Oil & Gas, Data Centers</td>
                                <td>Comprehensive QMS standard ensuring consistent manufacturing processes, continuous improvement, and customer satisfaction.</td>
                            </tr>
                            <tr>
                                <th scope="row">IATF 16949</th>
                                <td>Automotive & Commercial Vehicles</td>
                                <td>Defect prevention, reduction of supply chain variation, and advanced product quality planning (APQP) for high-volume production.</td>
                            </tr>
                            <tr>
                                <th scope="row">Nadcap Alignment</th>
                                <td>Aerospace & Defense</td>
                                <td>Certified oversight for Special Processes, including Non-Destructive Testing (NDT), Heat Treatment, and Chemical Surface Plating.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="document-control">
            <div class="content-container">
                <h2>Advanced Document Control & Traceability</h2>
                <p>
                    We provide comprehensive quality documentation packages tailored to your project’s specific compliance mandates. Our engineering and quality teams seamlessly integrate with your internal portals to deliver:
                </p>
                <ul>
                    <li>
                        <strong>AS9102 First Article Inspection (FAI):</strong> Complete dimensional mapping and process verification for aerospace and defense hardware.
                    </li>
                    <li>
                        <strong>Production Part Approval Process (PPAP):</strong> Level 1 through Level 5 PPAP submissions, including Control Plans, FMEAs, and Capability Studies for automotive and industrial clients.
                    </li>
                    <li>
                        <strong>Certified Material Test Reports (EN 10204 3.1):</strong> Unbroken chain of custody tracing exact chemical composition, tensile strength, and hardness properties back to the original heat/melt lot.
                    </li>
                </ul>
            </div>
        </section>

        <section id="tier-1-5-quality-umbrella">
            <div class="content-container">
                <h2>The Tier-1.5 Quality Umbrella</h2>
                <p>
                    In fragmented supply chains, defects often occur during vendor hand-offs (e.g., a foundry shipping an out-of-tolerance casting to a third-party machine shop). By executing casting, forging, Hot Isostatic Pressing (HIP), and 5-axis CNC machining under a single, unified quality umbrella, ForceBeyond eliminates dimensional disputes, reduces administrative friction, and assumes 100% accountability for the final component.
                </p>
            </div>
        </section>

    </div>
</IndividualPageLayout>