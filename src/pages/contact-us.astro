---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';

// 1. Fetch Dynamic Cloud Configuration from Sanity
const data = await sanityClient.fetch(`*[_type == "contactPage"][0]`);

const countries = ['Afghanistan', 'Albania', 'Algeria', 'Andorra', 'Angola', 'Antigua and Barbuda', 'Argentina', 'Armenia', 'Australia', 'Austria', 'Azerbaijan', 'Bahamas', 'Bahrain', 'Bangladesh', 'Barbados', 'Belarus', 'Belgium', 'Belize', 'Benin', 'Bhutan', 'Bolivia', 'Bosnia and Herzegovina', 'Botswana', 'Brazil', 'Brunei', 'Bulgaria', 'Burkina Faso', 'Burundi', 'Cabo Verde', 'Cambodia', 'Cameroon', 'Canada', 'Central African Republic', 'Chad', 'Chile', 'China', 'Colombia', 'Comoros', 'Congo (Congo-Brazzaville)', 'Costa Rica', 'Croatia', 'Cuba', 'Cyprus', 'Czechia', 'Democratic Republic of the Congo', 'Denmark', 'Djibouti', 'Dominica', 'Dominican Republic', 'Ecuador', 'Egypt', 'El Salvador', 'Equatorial Guinea', 'Eritrea', 'Estonia', 'Eswatini', 'Ethiopia', 'Fiji', 'Finland', 'France', 'Gabon', 'Gambia', 'Georgia', 'Germany', 'Ghana', 'Greece', 'Grenada', 'Guatemala', 'Guinea', 'Guinea-Bissau', 'Guyana', 'Haiti', 'Honduras', 'Hungary', 'Iceland', 'India', 'Indonesia', 'Iran', 'Iraq', 'Ireland', 'Israel', 'Italy', 'Jamaica', 'Japan', 'Jordan', 'Kazakhstan', 'Kenya', 'Kiribati', 'Kuwait', 'Kyrgyzstan', 'Laos', 'Latvia', 'Lebanon', 'Lesotho', 'Liberia', 'Libya', 'Liechtenstein', 'Lithuania', 'Luxembourg', 'Madagascar', 'Malawi', 'Malaysia', 'Maldives', 'Mali', 'Malta', 'Marshall Islands', 'Mauritania', 'Mauritius', 'Mexico', 'Micronesia', 'Moldova', 'Monaco', 'Mongolia', 'Montenegro', 'Morocco', 'Mozambique', 'Myanmar', 'Namibia', 'Nauru', 'Nepal', 'Netherlands', 'New Zealand', 'Nicaragua', 'Niger', 'Nigeria', 'North Korea', 'North Macedonia', 'Norway', 'Oman', 'Pakistan', 'Palau', 'Panama', 'Papua New Guinea', 'Paraguay', 'Peru', 'Philippines', 'Poland', 'Portugal', 'Qatar', 'Romania', 'Russia', 'Rwanda', 'Saint Kitts and Nevis', 'Saint Lucia', 'Saint Vincent and the Grenadines', 'Samoa', 'San Marino', 'Sao Tome and Principe', 'Saudi Arabia', 'Senegal', 'Serbia', 'Seychelles', 'Sierra Leone', 'Singapore', 'Slovakia', 'Slovenia', 'Solomon Islands', 'Somalia', 'South Africa', 'South Korea', 'South Sudan', 'Spain', 'Sri Lanka', 'Sudan', 'Suriname', 'Sweden', 'Switzerland', 'Syria', 'Taiwan', 'Tajikistan', 'Tanzania', 'Thailand', 'Timor-Leste', 'Togo', 'Tonga', 'Trinidad and Tobago', 'Tunisia', 'Turkey', 'Turkmenistan', 'Tuvalu', 'Uganda', 'Ukraine', 'United Arab Emirates', 'United Kingdom', 'Uruguay', 'Uzbekistan', 'Vanuatu', 'Vatican City', 'Venezuela', 'Vietnam', 'Yemen', 'Zambia', 'Zimbabwe', 'United States of America'];

const sources = ['Cold Call', 'Direct Mail', 'Email', 'Industry Event', 'Referral', 'Search Engine', 'Web Research', 'AI Search (ChatGPT/Gemini/Claude)'];

// 统一的表单输入框样式 - 纯白微透明底色，聚焦蓝色高亮
const input = 'mt-2 w-full border border-slate-200 transition-all duration-300 bg-white px-5 py-3.5 text-slate-900 text-sm font-medium outline-none focus:border-blue-600 focus:ring-1 focus:ring-blue-100 placeholder:text-slate-400';

const contactSchema = {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    '@id': 'https://fbwebdemo.netlify.app/contact-us/#contact',
    name: data?.title || 'Contact ForceBeyond',
    url: 'https://fbwebdemo.netlify.app/contact-us/',
    mainEntity: {
        '@type': 'IndustrialBusiness',
        name: data?.companyName || 'ForceBeyond',
        telephone: data?.phone || '+1-302-995-6588',
        email: data?.email || 'contact@forcebeyond.com',
        address: { 
            '@type': 'PostalAddress', 
            streetAddress: data?.streetAddress || '261 Quigley Blvd, Suite 18', 
            addressLocality: data?.locality || 'New Castle', 
            addressRegion: data?.region || 'DE', 
            postalCode: data?.postalCode || '19720', 
            addressCountry: 'US' 
        },
        geo: { '@type': 'GeoCoordinates', latitude: 39.6621, longitude: -75.5663 }
    }
};
---

<Layout title="Contact Corporate Access | ForceBeyond" description={data?.seoDescription || "Submit your metal manufacturing requirements to ForceBeyond."}>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(contactSchema)}></script>
    
<!-- ========================================= -->
<!-- SECTION 1: CONTACT HERO IMAGE -->
<!-- ========================================= -->
<section class="relative z-20 w-full h-[420px] lg:h-[500px] flex items-center justify-center bg-slate-950 overflow-hidden border-b border-white/5">
    <img 
        src="/oscar/media/trust.webp" 
        alt="Contact ForceBeyond"
        class="absolute inset-0 z-0 h-full w-full object-cover object-center"
    />

    <!-- 轻微遮罩，只保证文字可读，不压暗图片 -->
    <div class="absolute inset-0 z-1 bg-slate-950/25"></div>
    <div class="absolute inset-0 z-2 bg-gradient-to-r from-slate-950/45 via-transparent to-transparent"></div>
    
    <div class="relative z-10 mx-auto max-w-7xl px-6 sm:px-12 text-center">
        <h1 class="mt-3 text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl uppercase leading-none">
            Contact Us
        </h1>
    </div>
</section>

<!-- ========================================= -->
<!-- SECTION 2: MAP SECTION -->
<!-- ========================================= -->
<section class="relative z-10 w-full bg-white border-b border-slate-200 py-12">
    <div class="mx-auto max-w-7xl px-6 sm:px-12">
        
        <div class="mb-8 text-center">
            <h2 class="text-2xl sm:text-3xl font-black mt-2 text-slate-950 tracking-tight">Find Us On The Map</h2>
        </div>

        <div class="w-full rounded-xl overflow-hidden border border-slate-200 shadow-xl shadow-slate-900/10 bg-white h-[320px] sm:h-[420px] lg:h-[480px] relative">
            <iframe 
                src="https://maps.google.com/maps?q=39.6621,-75.5663&z=8&hl=en&output=embed"
                class="absolute inset-0 w-full h-full" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade"
                title="ForceBeyond LLC Global Headquarters Location"
            ></iframe>
        </div>

    </div>
</section>

    <!-- ========================================= -->
    <!-- SECTION 3: CORE B2B INQUIRY FORM (单列大气表单) -->
    <!-- ========================================= -->
    <section class="bg-slate-50 py-16 text-slate-900 sm:py-24 relative z-10">
    <div class="mx-auto max-w-7xl px-6 sm:px-12">
        
        <div class="grid grid-cols-1 lg:grid-cols-[0.85fr_1.65fr] gap-10 lg:gap-12 items-start">
            
            <!-- 左侧 Contact Info -->
            <aside class="bg-white rounded-2xl border border-slate-200/80 p-8 shadow-xl shadow-slate-900/5 text-slate-900 lg:sticky lg:top-28">
                <h3 class="text-2xl font-black mt-2 text-slate-950 tracking-tight">Forcebeyond</h3>
                
                <address class="mt-6 text-sm text-slate-600 not-italic leading-relaxed border-l-2 border-blue-600 pl-4">
                    {data?.streetAddress || "261 Quigley Blvd, Suite 18"}<br />
                    {data?.locality || "New Castle"}, {data?.region || "Delaware"} {data?.postalCode || "19720"}, USA
                </address>

                <div class="mt-8 space-y-6 text-sm">
                    <div>
                        <p class="text-[10px] font-black tracking-[0.2em] text-blue-600 uppercase">Phone</p>
                        <a href={`tel:${data?.phone || "+13029956588"}`} class="mt-2 inline-block text-slate-700 hover:text-blue-600 transition">
                            {data?.phone || "(302) 995 6588"}
                        </a>
                    </div>

                    <div>
                        <p class="text-[10px] font-black tracking-[0.2em] text-blue-600 uppercase">Email</p>
                        <a href={`mailto:${data?.email || "contact@forcebeyond.com"}`} class="mt-2 inline-block text-slate-700 hover:text-blue-600 transition break-all">
                            {data?.email || "contact@forcebeyond.com"}
                        </a>
                    </div>
                </div>

                <a href={`mailto:${data?.email || "contact@forcebeyond.com"}?subject=Web%20Conference%20Appointment`} class="mt-10 inline-flex w-full items-center justify-center rounded-full bg-blue-600 px-6 py-4 font-black tracking-widest text-white uppercase text-xs transition hover:bg-blue-700 hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-blue-600/10">
                    Schedule Web Conference
                </a>
            </aside>

            <!-- 右侧表单主体容器 -->
            <!-- 右侧表单主体容器 -->
            <div class="bg-white rounded-2xl border border-slate-200/80 p-8 shadow-xl shadow-slate-900/5 lg:p-14">

                <div id="thankYouState" class="hidden mx-auto max-w-2xl text-center">
                    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100 text-green-600">
                        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                    </div>

                    <h2 class="mt-6 text-3xl font-bold tracking-tight text-slate-900">Thank You!</h2>

                    <p class="mt-4 text-lg text-slate-600">
                        Thank you so much for contacting us!
                        Your message has been safely received.
                        Our team will review your inquiry and get back to you soon.
                    </p>

                    <div class="mt-8">
                        <button 
                            type="button"
                            onclick="window.location.reload()" 
                            class="inline-flex items-center justify-center bg-slate-900 px-6 py-3 text-sm font-bold text-white transition hover:bg-slate-800"
                        >
                            Submit Another Message
                        </button>
                    </div>
                </div>
                            
                <form id="contactForm" action="/oscar/contact.php" method="POST" class="w-full">
                    <h2 class="text-2xl font-black tracking-tight text-slate-950 uppercase">{data?.formTitle || "B2B Technical Communications"}</h2>
                    <p class="mt-3 leading-relaxed text-slate-600 text-sm">{data?.formDescription || "A dedicated ForceBeyond engineer will evaluate your submission and respond within one business day."}</p>

                    <div class="mt-12 grid gap-x-6 gap-y-8 sm:grid-cols-2">
                        <fieldset class="contents">
                            <legend class="sm:col-span-2 text-sm font-black text-slate-900 uppercase tracking-wider">Primary Point of Contact <span class="text-blue-600">*</span></legend>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">First Name<input class={input} required name="first-name" autocomplete="given-name" type="text" /></label>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Last Name<input class={input} required name="last-name" autocomplete="family-name" type="text" /></label>
                        </fieldset>

                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Your Job Title <span class="text-blue-600">(required)</span><input class={input} required name="job-title" autocomplete="organization-title" type="text" /></label>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Your Company Name <span class="text-blue-600">(required)</span><input class={input} required name="company-name" autocomplete="organization" type="text" /></label>

                        <fieldset class="contents">
                            <legend class="sm:col-span-2 mt-4 text-sm font-black text-slate-900 uppercase tracking-wider">Manufacturing Location <span class="text-blue-600">(required)</span></legend>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider sm:col-span-2">Address Line 1<input class={input} required name="address-line-1" autocomplete="address-line1" type="text" /></label>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider sm:col-span-2">Address Line 2 (Optional)<input class={input} name="address-line-2" autocomplete="address-line2" type="text" /></label>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">City<input class={input} required name="city" autocomplete="address-level2" type="text" /></label>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">State / Province<input class={input} required name="state-region" autocomplete="address-level1" type="text" /></label>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Postal Code<input class={input} required name="postal-code" autocomplete="postal-code" type="text" /></label>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">
                                Country
                                <select class={input} required name="country" autocomplete="country-name">
                                    <option value="">Select a country</option>
                                    {countries.map((country) => <option value={country}>{country}</option>)}
                                </select>
                            </label>
                        </fieldset>

                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Verified Corporate Email <span class="text-blue-600">(required)</span><input id="contact-email" class={input} required name="email" autocomplete="email" type="email" /></label>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Confirm Corporate Email<input id="contact-confirm-email" class={input} required name="confirm-email" autocomplete="email" type="email" /></label>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider sm:col-span-2">Your Business Phone <span class="text-blue-600">(Required)</span><input class={input} required name="phone" autocomplete="tel" type="tel" /></label>

                        <fieldset class="sm:col-span-2 border-y border-slate-200 py-8 my-2">
                            <legend class="text-sm font-black text-slate-900 uppercase tracking-wider">Referral Source <span class="text-blue-600">(required)</span></legend>
                            <div class="mt-6 grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                                {sources.map((source) => (
                                    <label class="flex cursor-pointer items-center gap-3 rounded border border-slate-200 bg-slate-50/50 px-4 py-3 text-xs font-bold text-slate-700 transition hover:border-blue-500 hover:bg-slate-50">
                                        <input required type="radio" name="marketing-source" value={source} class="h-4 w-4 accent-blue-600" />{source}
                                    </label>
                                ))}
                            </div>
                        </fieldset>

                        <label class="block text-sm font-black text-slate-900 uppercase tracking-wider sm:col-span-2">Technical Subject / Requirement <span class="text-blue-600">(required)</span><input class={input} required name="subject" type="text" /></label>
                        <label class="block text-sm font-black text-slate-900 uppercase tracking-wider sm:col-span-2">
                            Core Inquiry / Manufacturing Specifications <span class="text-blue-600">(required)</span>
                            <textarea 
                                class={input + ' min-h-48 resize-y'} 
                                required 
                                name="message" 
                                placeholder="Please provide casting/forging grades, annual volume estimates, secondary processing, or critical tolerances..."
                            ></textarea>
                        </label>
                    </div>

                    <!-- 统一的首页圆形饱满蓝色提交按钮 -->
                    <div class="mt-10 text-center sm:text-left">
                        <button type="submit" id="submitBtn" class="inline-flex items-center justify-center rounded-full bg-blue-600 px-12 py-4.5 font-black tracking-widest text-white uppercase text-xs transition hover:bg-blue-700 hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-blue-600/10 cursor-pointer">
                            Submit
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
        <!-- Email匹配验证小脚本 -->
        <script is:inline>
            const emailInput = document.getElementById('contact-email');
            const confirmEmailInput = document.getElementById('contact-confirm-email');

            function validateEmail() {
                if (confirmEmailInput.value && emailInput.value !== confirmEmailInput.value) {
                    confirmEmailInput.setCustomValidity("Email addresses must match.");
                } else {
                    confirmEmailInput.setCustomValidity("");
                }
            }

            emailInput.addEventListener('input', validateEmail);
            confirmEmailInput.addEventListener('input', validateEmail);
        </script>
        <script is:inline>
            const contactForm = document.getElementById('contactForm');
            const contactSubmitBtn = document.getElementById('submitBtn');
            const contactThankYouState = document.getElementById('thankYouState');

            if (contactForm && contactSubmitBtn && contactThankYouState) {
                contactForm.addEventListener('submit', async (e) => {
                    e.preventDefault();

                    contactSubmitBtn.textContent = 'Submitting...';
                    contactSubmitBtn.disabled = true;

                    const formData = new FormData(contactForm);

                    try {
                        const response = await fetch(contactForm.action, {
                            method: 'POST',
                            body: formData
                        });

                        let result;
                        const contentType = response.headers.get('content-type');

                        if (contentType && contentType.includes('application/json')) {
                            result = await response.json();
                        } else {
                            const textResponse = await response.text();
                            result = { success: response.ok, error: textResponse };
                        }

                        if (result.success || response.ok) {
                            contactForm.reset();
                            contactForm.classList.add('hidden');
                            contactThankYouState.classList.remove('hidden');
                            window.scrollTo({
                                top: contactThankYouState.offsetTop - 120,
                                behavior: 'smooth'
                            });
                        } else {
                            alert('Submission failed: ' + (result.error || 'Unknown server error.'));
                        }
                    } catch (error) {
                        alert('A transmission error occurred. Please try again.');
                    } finally {
                        contactSubmitBtn.textContent = 'Submit';
                        contactSubmitBtn.disabled = false;
                    }
                });
            }
        </script>
    </section>
</Layout>