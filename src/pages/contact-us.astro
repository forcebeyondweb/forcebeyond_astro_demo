const sources = ['Cold Call', 'Email', 'Newsletter', 'Publications', 'Referral', 'Web Research'];

const input = 'mt-2 w-full border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-orange-600 focus:ring-2 focus:ring-orange-100';

// 2. 动态组装 GEO 核心资产：JSON-LD 随着 Sanity 后台的数据变动而自动变动！
const contactSchema = {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    '@id': 'https://fbwebdemo.netlify.app/contact-us/#contact',
    name: data?.title || 'Contact ForceBeyond',
    url: 'https://fbwebdemo.netlify.app/contact-us/',
    mainEntity: {
        '@type': 'IndustrialBusiness',
        name: data?.companyName || 'ForceBeyond',
        telephone: data?.phone || '+1-302-995-6588',
        email: data?.email || 'contact@forcebeyond.com',
        address: { 
            '@type': 'PostalAddress', 
            streetAddress: data?.streetAddress || '261 Quigley Blvd, Suite 18', 
            addressLocality: data?.locality || 'New Castle', 
            addressRegion: data?.region || 'DE', 
            postalCode: data?.postalCode || '19720', 
            addressCountry: 'US' 
        },
        geo: { '@type': 'GeoCoordinates', latitude: 39.6621, longitude: -75.5663 }
    }
};
---

<Layout title="Contact Us | ForceBeyond" description={data?.seoDescription || "Contact ForceBeyond..."}>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(contactSchema)}></script>
    
    <section class="border-b border-white/10 bg-slate-900">
        <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
            <p class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">{data?.badge}</p>
            <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">{data?.title}</h1>
        </div>
    </section>

    <section class="bg-slate-100 py-14 text-slate-900 sm:py-20">
        <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr] lg:px-8">
            <aside class="h-fit border-t-4 border-orange-600 bg-slate-900 p-7 text-white sm:p-8">
                <p class="text-sm font-bold tracking-[0.2em] text-orange-500 uppercase">Corporate Access Info</p>
                <h2 class="mt-4 text-2xl font-bold">{data?.companyName}</h2>
                <address class="mt-7 border-t border-white/10 pt-6 text-base leading-7 text-slate-300 not-italic">
                    {data?.streetAddress}<br />{data?.locality}, {data?.region} {data?.postalCode}
                </address>
                </aside>

            <div>
                <form ...>
                    <h2 class="text-2xl font-bold">{data?.formTitle}</h2>
                    <p class="mt-3 leading-7 text-slate-600">{data?.formDescription}</p>
                    </form>
            </div>
        </div>
    </section>
</Layout>