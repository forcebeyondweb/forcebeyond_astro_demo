---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Inconel 718 Machining Services: Precision 5-Axis CNC & Turning';
const seoTitle = 'Inconel 718 Machining Services | Precision 5-Axis CNC | ForceBeyond';
const seoDescription = 'AS9100-certified Inconel 718 machining by ForceBeyond. Precision 5-axis CNC milling & turning managed via Delaware with production in USA, SK & Taiwan.';
const faqs = [
    {
        q: "Where are ForceBeyond’s engineering and Inconel 718 machining operations located?",
        a: "ForceBeyond’s dedicated engineering team is based in Delaware, USA, which manages your project from start to finish. Our co-owned advanced manufacturing and CNC machining facilities are strategically located across the USA, South Korea, and Taiwan to provide globally optimized production and pricing."
    },
    {
        q: "Does ForceBeyond offer single-source integration for Inconel 718 forging, casting, and machining?",
        a: "Yes. As a Tier-1.5 manufacturing partner, ForceBeyond seamlessly integrates our 5-axis CNC machining centers with our in-house <a href='/oscar/inconel-718-forging' class='highlight-link'>Inconel 718 Forging</a> and <a href='/oscar/inconel-718-casting' class='highlight-link'>Inconel 718 Casting</a> operations. This single-source approach is managed by our Delaware engineering team and executed across our facilities in the USA, South Korea, and Taiwan to eliminate third-party supply chain risks."
    },
    {
        q: "What specific quality certifications and inspection standards do your facilities follow?",
        a: "All ForceBeyond facilities operate under a unified AS9100 Rev D quality framework providing full Heat Lot Traceability. For verification, we utilize CMM Inspection for 5-axis geometries (± 0.005mm accuracy), Fluorescent Penetrant Inspection (FPI) to detect surface-breaking cracks (ASTM E1417 / Nadcap), Ultrasonic Testing (UT) for internal voids (AMS 2154), and Hardness Testing (36 – 44 HRC)."  
    },
    {
        q:"Can ForceBeyond machine Inconel 718 in both the annealed and age-hardened states?",
        a: "Yes. We optimize production routing based on your print specifications. We perform heavy material removal (roughing) in the Solution Annealed State (AMS 5662) while the alloy is softer (approx. 20-25 HRC). To guarantee tight aerospace tolerances without risking dimensional distortion from heat treatment, we perform finish machining in the Age-Hardened State (AMS 5663) at 36–44 HRC using advanced PVD-coated solid carbide tooling."
    },
    {
        q: "How do your machining facilities prevent tool deformation and work-hardening on Inconel 718?",
        a: "We combat low thermal conductivity and work-hardening by utilizing high-torque spindles, rigid workholding, and high-pressure coolant. During roughing, we use SiAlON and whisker-reinforced ceramic tooling at cutting speeds up to 1,000 SFM. To prevent work-hardening caused by tool rubbing, we enforce strict climb-milling (thick-to-thin) toolpaths, maintain continuous feed rates, and never allow the cutting tool to dwell in the cut."
    }
];

// Sources 
const sources = [
    { label: 'American Foundry Society: "Metal Casting"', url: 'https://www.afsinc.org' },
    { label: 'Forging Industry Association: "Forging Industry"', url: 'https://www.forging.org' },
    { label: 'efunda. “Sand Casting“', url: 'https://www.efunda.com/processes/metal_processing/sand_casting_intro.cfm' },
    { label: 'The Investment Casting Institute. “What is Investment Casting?“',url:'https://www.investmentcasting.org/what-is-investment-casting.html'},
    { label: 'ASM International. “Inconel 718 Alloy“', url: 'https://www.asminternational.org/materials-resources/alloy-database/technical-bulletin/inconel-718-alloy' }
];

// Resources 
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
