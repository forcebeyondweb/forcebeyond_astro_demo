---
import IndividualPageLayout from '../layouts/IndividualPageLayout.astro';

const pageTitle = 'Technical Insights, News & Case Studies | ForceBeyond Resource Center';
const seoTitle = 'Technical Insights, News & Case Studies | ForceBeyond';
const seoDescription = 'Explore ForceBeyond engineering case studies, white papers, technical insights, and company announcements detailing our Tier-1.5 manufacturing solutions.';

const faqs = [
    {
        q: "Can ForceBeyond provide customized case studies or sample parts for our engineering team?",
        a: "Yes. We frequently partner with OEM engineering teams during the First Article Inspection (FAI) and APQP stages to provide full First Article Inspection Reports (AS9102), CMM dimensional maps, metallurgical microstructural photos, and material test certifications."
    },
    {
        q: "How can I submit my project prints for a technical quote or feasibility review?",
        a: "You can submit your 3D CAD models (STEP/IGES) and 2D engineering prints directly through our online RFQ portal, or contact our Delaware-based engineering management team directly. Every inquiry receives a comprehensive manufacturing feasibility review within 24 to 48 hours."
    }
];

// Sources
const sources = [
    { label: 'ISO 9001:2015 Quality Management Systems Requirements', url: 'https://www.iso.org' },
    { label: 'AS9100 / AS9102 Aerospace Quality Management and FAI Standards', url: 'https://www.sae.org' },
    { label: 'ASTM International: Standards for Radiographic & NDT Inspection', url: 'https://www.astm.org' },
    { label: 'NACE International / ISO 15156: Materials for Use in H2S-Containing Environments', url: 'https://www.nace.org' }
];

// Resources
const internalResources = [
    // Die Casting Resources
    { label: "Die Casting Overview", url: "/oscar/die-casting" },
    { label: "Aluminum Die Casting", url: "/oscar/aluminum-die-casting" },
    { label: "Zinc Die Casting", url: "/oscar/zinc-die-casting" },
    { label: "A356-T6 Casting", url: "/oscar/a356-t6-casting" },
    { label: "Magnesium Casting", url: "/oscar/magnesium-casting" },

    // Investment Casting Resources
    { label: "Investment Casting Overview", url: "/oscar/investment-casting" },
    { label: "Inconel Vacuum Precision Casting", url: "/oscar/inconel-vacuum-precision-casting" },
    { label: "Titanium Investment Casting", url: "/oscar/titanium-investment-casting" },
    { label: "Stainless Steel Casting", url: "/oscar/stainless-steel-casting" },
    { label: "Duplex & Super Duplex Stainless Steel Casting", url: "/oscar/duplex-stainless-steel-casting" },

    // Forging Resources
    { label: "Forging Capabilities Overview", url: "/oscar/forging" },
    { label: "Open Die Forging", url: "/oscar/open-die-forging" },
    { label: "Closed Die Forging", url: "/oscar/closed-die-forging" },
    { label: "Rolled Ring Forging", url: "/oscar/rolled-ring-forging" },
    { label: "Cold Forging", url: "/oscar/cold-forging" },
    { label: "Superalloy Forging Services", url: "/oscar/superalloy-forging-services" },

    // Sand Casting & Steel Casting Resources
    { label: "Sand Casting", url: "/oscar/sand-casting" },
    { label: "Industrial Titanium Sand Casting", url: "/oscar/industrial-titanium-sand-casting" },
    { label: "Carbon & Low-Alloy Steel Casting", url: "/oscar/carbon-steel-casting" }
];

// WebPage Schema
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.forcebeyond.store/oscar/resource-center#webpage",
      "url": "https://www.forcebeyond.store/oscar/resource-center",
      "name": seoTitle,
      "description": seoDescription,
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://www.forcebeyond.store/oscar#website",
        "name": "ForceBeyond",
        "url": "https://www.forcebeyond.store/oscar"
      }
    },
    {
      "@type": "Organization",
      "@id": "https://www.forcebeyond.store/oscar#organization",
      "name": "ForceBeyond",
      "url": "https://www.forcebeyond.store/oscar",
      "knowsAbout": [
        "Vacuum Precision Casting (VIM) & Investment Casting",
        "Hot Isostatic Pressing (HIP) Microporosity Elimination",
        "Directionally Solidified (DS) Superalloy Turbine Components",
        "NACE MR0175 Compliant Super Duplex 2507 Castings",
        "Ti-6Al-4V Closed-Die Forgings for Severe Environments"
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.forcebeyond.store/oscar/resource-center#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<IndividualPageLayout
    title={seoTitle}
    description={seoDescription}
    schema={pageSchema}
    pageTitle={pageTitle}
    heroImage="/oscar/media/precision-cnc-machining-metal-manufacturing-workshop-hero.webp"
    heroImageAlt="Forged Inconel 718 rings and high-performance industrial components"
    faqSectionTitle="Frequently Asked Questions"
    faqItems={faqs}
    ctaTitle="Ready to Start Your Project?"
    ctaDescription="Contact our Delaware-based engineering management team or submit your 3D CAD models and prints for a comprehensive manufacturing feasibility review within 24 to 48 hours."
    sourcesTitle="Sources"
    sourcesList={sources}
    resourcesTitle="Our Internal Resources for Die Casting, Investment casting, Forging and Sand Casting"
    resourcesList={internalResources}
>

    <div slot="full-width" class="individual-content">

        <section id="overview">
            <div class="content-container">
                
                <h2>Welcome to the ForceBeyond Resource Center</h2>

                <div class="grid gap-10 lg:grid-cols-2 lg:items-center mt-6">
                    <div>
                        <p>
                            Welcome to the ForceBeyond Resource Center. Explore our latest engineering case studies, white papers, technical insights, and company announcements. Learn how our Tier-1.5 Manufacturing Model—combining Vacuum Precision Casting (VIM), heavy closed-die forging, Hot Isostatic Pressing (HIP), and 5-axis CNC machining—solves complex supply chain, metallurgical, and tight-tolerance challenges for global OEMs.
                        </p>
                    </div>
                    <div class="relative">
                        <div class="overflow-hidden">
                            <img
                                src="/oscar/media/resource-center-overview-4k.webp"
                                alt="High-precision engineered metal components and technical case study documentation."
                                class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500"
                            />
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section id="case-studies">
            <div class="content-container">
                <h2>Featured Engineering Case Studies</h2>
                
                <h3>1. Aerospace & Defense: Eliminating Microporosity in Jet Engine Turbine Vanes</h3>
                <p>
                    <strong>The Challenge:</strong> A Tier-1 aerospace prime faced high scrap rates (over 18%) due to internal shrinkage microporosity in thin-walled Inconel 718 nozzle guide vanes poured at a third-party foundry.
                </p>
                <p>
                    <strong>The ForceBeyond Solution:</strong> We transitioned production to our co-owned Vacuum Induction Melting (VIM) investment foundry, integrated mandatory Hot Isostatic Pressing (HIP) at 15,000+ psi, and completed final 5-axis CNC machining in-house.
                </p>
                <p>
                    <strong>The Outcome:</strong> Reduced internal scrap rates to &lt;0.2%, passed 100% Radiographic Testing (X-Ray per ASTM E192), and shortened total production lead time by 12 weeks through single-source execution.
                </p>
                <p>
                    <strong>Key Standards:</strong> AS9100 Rev D, AMS 5383, ASTM E1417 (FPI).
                </p>

                <hr class="my-8" />

                <h3>2. AI Data Center Infrastructure: Rapid-Deployment HGP Turbine Components</h3>
                <p>
                    <strong>The Challenge:</strong> A hyperscale AI data center developer required custom Hot Gas Path (HGP) turbine nozzles and buckets for a 250MW on-site natural gas microgrid under an aggressive 16-week deployment timeline.
                </p>
                <p>
                    <strong>The ForceBeyond Solution:</strong> Leveraging our directionally solidified (DS) vacuum casting and in-house multi-axis superalloy machining centers, ForceBeyond delivered fully machined, thermal-barrier-coated (TBC) Inconel 738 turbine buckets and Hastelloy X fuel nozzles.
                </p>
                <p>
                    <strong>The Outcome:</strong> The microgrid achieved commercial operation on schedule, providing continuous 24/7 power to 100,000+ GPUs with zero operational drift.
                </p>
                <p>
                    <strong>Key Standards:</strong> ISO 9001:2015, AS9100, 100% CMM Dimensional Mapping.
                </p>

                <hr class="my-8" />

                <h3>3. Nuclear & SMR Energy: Super Duplex 2507 Primary Loop Valve Bodies</h3>
                <p>
                    <strong>The Challenge:</strong> An SMR (Small Modular Reactor) developer needed high-pressure primary cooling loop valve bodies capable of withstanding severe thermal creep and chloride stress corrosion cracking ($H_2S$) over a 60-year design lifespan.
                </p>
                <p>
                    <strong>The ForceBeyond Solution:</strong> We engineered a near-net-shape Super Duplex 2507 investment casting, executed solution annealing and rapid water quenching to ensure an exact 50/50 ferrite-austenite phase balance, and performed 100% Ultrasonic (UT) and Radiographic (RT) testing.
                </p>
                <p>
                    <strong>The Outcome:</strong> Delivered fully certified, NACE MR0175/ISO 15156-compliant valve bodies with complete EN 10204 3.1 material traceability, passing all hydrostatic pressure tests at 10,000+ psi.
                </p>
                <p>
                    <strong>Key Standards:</strong> ASME Section III, NACE MR0175, ASTM A890/A995.
                </p>

                <hr class="my-8" />

                <h3>4. Oil & Gas / Subsea: Monel & Titanium Forged Mud Pump Components</h3>
                <p>
                    <strong>The Challenge:</strong> Offshore drilling operators experienced catastrophic fatigue failure on carbon steel mud pump fluid ends operating in deepwater sour gas conditions.
                </p>
                <p>
                    <strong>The ForceBeyond Solution:</strong> ForceBeyond converted the heavy fluid end block to a high-tonnage closed-die Ti-6Al-4V Titanium forging, followed by precision deep-hole boring and high-pressure liquid penetrant inspection.
                </p>
                <p>
                    <strong>The Outcome:</strong> Increased component service life by 400%, reduced overall assembly weight by 42%, and completely eliminated sour-gas corrosion failures.
                </p>
                <p>
                    <strong>Key Standards:</strong> API Spec 16A, ISO 15156, ASTM B381.
                </p>
            </div>
        </section>

        <section id="company-news">
            <div class="content-container">
                <h2>Recent Company News & Press Releases</h2>
                <ul>
                    <li>
                        <strong>ForceBeyond Expands Dual-Shore Superalloy Manufacturing Capacity</strong>
                        <br />
                        <em>Category: Company News | Corporate</em>
                        <p>
                            To support surging global demand in aerospace and SMR nuclear energy, ForceBeyond has expanded its co-owned manufacturing footprint across the USA, South Korea, and Taiwan. The expansion adds automated VIM furnaces, additional 15,000 psi HIP vessels, and high-speed 5-axis DMG MORI CNC milling centers.
                        </p>
                    </li>
                    <li>
                        <strong>White Paper: Solving Supply Chain Friction with the Tier-1.5 Model</strong>
                        <br />
                        <em>Category: Technical White Paper | Supply Chain</em>
                        <p>
                            Discover how consolidating primary forming (casting/forging), thermal processing (Heat Treatment/HIP), and secondary finishing (CNC Machining/Coating) under one managed quality system eliminates vendor hand-off errors, reduces scrap costs, and cuts lead times by up to 40%.
                        </p>
                    </li>
                    <li>
                        <strong>Compliance Update: Meeting Strict NACE MR0175 Standards for Duplex Alloys</strong>
                        <br />
                        <em>Category: Technical Insight | Quality Control</em>
                        <p>
                            An in-depth metallurgical analysis on maintaining phase balance in 2205 and 2507 Duplex stainless steels during secondary CNC machining and heat treatment to prevent harmful Sigma phase formation in sour gas service.
                        </p>
                    </li>
                </ul>
            </div>
        </section>

        <section id="knowledge-center">
            <div class="content-container">
                <h2>Knowledge Center & Technical Resources</h2>
                <p>
                    Looking for specific technical data, material selection guides, or tolerance tables? Browse our dedicated technical resources:
                </p>
                <div class="content-table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th scope="col">Resource Category</th>
                                <th scope="col">Topic Covered</th>
                                <th scope="col">Download / Link</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <th scope="row">Material Guides</th>
                                <td>Inconel 718 vs. 625: Mechanical Properties & Machinability</td>
                                <td><a href="#">Read Technical Guide</a></td>
                            </tr>
                            <tr>
                                <th scope="row">Process Comparison</th>
                                <td>Investment Casting vs. Closed-Die Forging for High-Stress Alloys</td>
                                <td><a href="#">View Comparison Matrix</a></td>
                            </tr>
                            <tr>
                                <th scope="row">Quality & Compliance</th>
                                <td>Understanding EN 10204 3.1 vs. 3.2 Material Test Reports (MTRs)</td>
                                <td><a href="#">Learn More</a></td>
                            </tr>
                            <tr>
                                <th scope="row">Design Guidelines</th>
                                <td>Designing Near-Net-Shape Castings for 5-Axis CNC Machining</td>
                                <td><a href="#">Download PDF Guide</a></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

    </div>
</IndividualPageLayout>